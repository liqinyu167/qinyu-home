<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>好奇心导航 - 前后端分离 Demo</title>
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        background: #0f0f14;
        color: #e0e0e8;
        min-height: 100vh;
      }

      /* Header */
      header {
        background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
        padding: 2rem 1.5rem;
        text-align: center;
        border-bottom: 1px solid #2a2a4a;
      }
      header h1 {
        font-size: 1.8rem;
        background: linear-gradient(135deg, #64ffda, #48b1bf);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        margin-bottom: 0.5rem;
      }
      header p {
        color: #8888aa;
        font-size: 0.9rem;
      }
      header .badge {
        display: inline-block;
        background: #1a3a3a;
        color: #64ffda;
        padding: 0.2rem 0.8rem;
        border-radius: 12px;
        font-size: 0.8rem;
        margin-top: 0.5rem;
      }

      /* API 状态条 */
      .api-status {
        padding: 0.5rem 1.5rem;
        font-size: 0.8rem;
        text-align: center;
      }
      .api-status.online { color: #64ffda; background: #0a1a1a; border-bottom: 1px solid #1a3a3a; }
      .api-status.offline { color: #ff6b6b; background: #1a0a0a; border-bottom: 1px solid #3a1a1a; }

      /* 导航网格 */
      .container { max-width: 1200px; margin: 0 auto; padding: 1.5rem; }
      
      .stats-bar {
        display: flex; gap: 1rem; justify-content: center;
        margin-bottom: 1.5rem; flex-wrap: wrap;
      }
      .stat-card {
        background: #1a1a2e;
        border: 1px solid #2a2a4a;
        border-radius: 8px;
        padding: 0.8rem 1.5rem;
        text-align: center;
        min-width: 100px;
      }
      .stat-card .num { font-size: 1.5rem; font-weight: bold; color: #64ffda; }
      .stat-card .label { font-size: 0.75rem; color: #6666aa; margin-top: 0.2rem; }

      /* 站点卡片网格 */
      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 1rem;
      }
      .card {
        background: #1a1a2e;
        border: 1px solid #2a2a4a;
        border-radius: 10px;
        padding: 1rem 1.2rem;
        transition: all 0.2s;
      }
      .card:hover {
        border-color: #64ffda44;
        transform: translateY(-2px);
        box-shadow: 0 4px 20px #64ffda11;
      }
      .card h3 { font-size: 1rem; margin-bottom: 0.3rem; }
      .card h3 a { color: #e0e0e8; text-decoration: none; }
      .card h3 a:hover { color: #64ffda; }
      .card .desc { font-size: 0.8rem; color: #6666aa; line-height: 1.4; }
      .card .tags { margin-top: 0.5rem; display: flex; gap: 0.3rem; flex-wrap: wrap; }
      .card .tag {
        font-size: 0.65rem;
        padding: 0.15rem 0.5rem;
        border-radius: 6px;
        background: #222244;
        color: #8888cc;
      }

      /* 加载/错误 */
      .loading, .error {
        text-align: center; padding: 3rem;
        color: #6666aa;
      }
      .error { color: #ff6b6b; }

      /* Footer */
      footer {
        text-align: center; padding: 2rem;
        color: #444466; font-size: 0.8rem;
        border-top: 1px solid #1a1a2e;
      }
      footer .arch {
        background: #1a1a2e; border-radius: 6px;
        padding: 0.5rem 1rem; margin-top: 0.5rem;
        display: inline-block;
      }
      footer .arch span {
        display: inline-block; padding: 0.2rem 0.5rem;
        margin: 0.2rem; border-radius: 4px;
        font-size: 0.7rem;
      }
      footer .arch .fe { background: #1a3a3a; color: #64ffda; }
      footer .arch .be { background: #3a1a3a; color: #da70d6; }
      footer .arch .gw { background: #2a2a1a; color: #ffd700; }
    </style>
  </head>
  <body>
    <header>
      <h1>🧭 好奇心导航</h1>
      <p>AI 工具导航 · 前后端分离演示</p>
      <div class="badge">⚡ Astro + FastAPI Demo</div>
    </header>

    <!-- API 状态 -->
    <div id="api-status" class="api-status">⏳ 连接 API 中…</div>

    <div class="container">
      <!-- 统计 -->
      <div class="stats-bar" id="stats-bar"></div>

      <!-- 站点网格 -->
      <div id="site-grid">
        <div class="loading">⏳ 加载导航数据…</div>
      </div>
    </div>

    <footer>
      <p>🪄 白刀的好奇心网站 · 技术演示</p>
      <div class="arch">
        <span class="fe">🟢 Astro 前端</span>
        <span class="be">🟣 FastAPI 后端</span>
        <span class="gw">🟡 Nginx 反代</span>
      </div>
    </footer>

    <script>
      const API_BASE = '/demo/api';

      async function main() {
        const statusEl = document.getElementById('api-status');
        const gridEl = document.getElementById('site-grid');
        const statsEl = document.getElementById('stats-bar');

        try {
          // 先检查 API 健康
          const health = await fetch(`${API_BASE}/health`).then(r => r.json());
          statusEl.textContent = `✅ API 在线 · ${health.message}`;
          statusEl.className = 'api-status online';

          // 加载导航数据
          const data = await fetch(`${API_BASE}/sites`).then(r => r.json());
          const stats = await fetch(`${API_BASE}/stats`).then(r => r.json());

          const sites = data.sites || [];

          // 统计卡片
          if (stats.categories && stats.categories.length > 0) {
            statsEl.innerHTML = stats.categories.map(c =>
              `<div class="stat-card">
                <div class="num">${c.count}</div>
                <div class="label">${c.name}</div>
              </div>`
            ).join('');
          }
          statsEl.innerHTML +=
            `<div class="stat-card">
              <div class="num">${sites.length}</div>
              <div class="label">全部站点</div>
            </div>`;

          // 站点卡片
          if (sites.length === 0) {
            gridEl.innerHTML = '<div class="error">暂无数据</div>';
            return;
          }

          gridEl.innerHTML = '<div class="grid"></div>';
          const grid = gridEl.querySelector('.grid');

          sites.forEach(s => {
            const card = document.createElement('div');
            card.className = 'card';
            card.innerHTML = `
              <h3><a href="${s.url || '#'}" target="_blank">${s.name || '未命名'}</a></h3>
              <div class="desc">${s.description || ''}</div>
              ${s.tags ? '<div class="tags">' + s.tags.map(t => `<span class="tag">${t}</span>`).join('') + '</div>' : ''}
            `;
            grid.appendChild(card);
          });

        } catch (err) {
          statusEl.textContent = '❌ API 连接失败（后端未启动）';
          statusEl.className = 'api-status offline';
          gridEl.innerHTML = `<div class="error">
            <p>❌ 无法加载数据</p>
            <p style="font-size:0.8rem;color:#888">${err.message}</p>
            <p style="font-size:0.8rem;margin-top:1rem">
              后端 API 未运行 · FastAPI 端口 8002<br>
              前端页面已加载（纯静态），但数据来自后端 API
            </p>
          </div>`;
        }
      }

      main();
    </script>
  </body>
</html>
