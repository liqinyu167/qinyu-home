      box-shadow: 0 0 0 4px rgba(192, 132, 252, 0.08), inset 0 0 24px rgba(192, 132, 252, 0.08);
      animation: focusPulse 0.65s ease-out 1;
    }

    .search-symbol {
      color: var(--ink-muted);
      font-size: 15px;
      text-align: center;
    }

    .search input {
      width: 100%;
      min-width: 0;
      border: 0;
      outline: 0;
      background: transparent;
      color: var(--ink-white);
      font-weight: 300;
    }

    .search input::placeholder {
      color: rgba(122, 113, 143, 0.82);
    }

    .clear-search {
      width: 34px;
      height: 34px;
      border: 0;
      border-radius: 999px;
      background: transparent;
      color: var(--ink-muted);
      font-family: "JetBrains Mono", monospace;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.2s, color 0.2s;
    }

    .clear-search.is-visible {
      opacity: 1;
      pointer-events: auto;
    }

    .clear-search:hover {
      color: var(--ink-coral);
    }

    .actions {
      display: flex;
      justify-content: flex-end;
      gap: 10px;
      align-items: center;
    }

    .icon-button,
    .random-button {
      min-width: 44px;
      min-height: 44px;
      border: 1px solid var(--border-ink);
      border-radius: 8px;
      background:
        linear-gradient(135deg, rgba(237, 232, 245, 0.055), rgba(192, 132, 252, 0.04)),
        rgba(15, 13, 26, 0.72);
      transition: transform 0.22s var(--ease-spring), border-color 0.22s, box-shadow 0.22s;
    }

    .icon-button {
      position: relative;
      display: inline-grid;
      place-items: center;
      font-family: "JetBrains Mono", monospace;
      font-size: 15px;
    }

    .random-button {
      display: inline-flex;
      gap: 8px;
      align-items: center;
      padding: 0 15px;
      color: var(--ink-white);
      font-family: "JetBrains Mono", monospace;
      font-size: 12px;
      letter-spacing: 0;
      white-space: nowrap;
    }

    .icon-button:hover,
    .random-button:hover {
      transform: translateY(-2px);
      border-color: rgba(192, 132, 252, 0.52);
      box-shadow: 0 8px 22px rgba(0, 0, 0, 0.24), 0 0 18px rgba(192, 132, 252, 0.12);
    }

    .badge {
      position: absolute;
      top: -6px;
      right: -6px;
      min-width: 18px;
      height: 18px;
      padding: 0 5px;
      border: 1px solid rgba(251, 191, 36, 0.42);
      border-radius: 999px;
      background: var(--ink-gold);
      color: #201102;
      font-size: 10px;
      line-height: 16px;
      text-align: center;
    }

    .sidebar {
      position: sticky;
      top: var(--topbar-h);
      left: 0;
      align-self: start;
      z-index: 30;
      grid-column: 1;
      grid-row: 2;
      width: var(--sidebar-w);
      height: calc(100dvh - var(--topbar-h));
      padding: 0;
      overflow: hidden;
      scrollbar-gutter: stable;
      scrollbar-width: thin;
      scrollbar-color: rgba(255, 255, 255, 0.7) rgba(255, 255, 255, 0.08);
      border-right: 1px solid var(--border-ink);
      background:
        linear-gradient(180deg, rgba(19, 17, 31, 0.94), rgba(15, 13, 26, 0.84)),
        repeating-linear-gradient(112deg, rgba(237, 232, 245, 0.03) 0 1px, transparent 1px 13px);
      backdrop-filter: blur(18px);
      animation: sidebarIn 0.5s ease-out 0.1s both;
      transition: opacity 0.28s ease, transform 0.28s ease;
    }

    body.sidebar-collapsed .toolbox-section {
      grid-template-columns: 0 minmax(0, 1fr);
    }

    body.sidebar-collapsed .sidebar {
      opacity: 0;
      pointer-events: none;
      transform: translateX(calc(-1 * var(--sidebar-w)));
    }

    body.sidebar-collapsed .main {
      grid-column: 1 / -1;
    }

    .sidebar::-webkit-scrollbar {
      width: 14px;
    }

    .sidebar::-webkit-scrollbar-track {
      border: 4px solid transparent;
      border-radius: 999px;
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.16), rgba(192, 132, 252, 0.08) 48%, rgba(251, 113, 133, 0.08)) padding-box,
        linear-gradient(180deg, rgba(255, 255, 255, 0.16), rgba(255, 255, 255, 0.02)) border-box;
      background-clip: padding-box, border-box;
      box-shadow:
        inset 0 0 0 1px rgba(255, 255, 255, 0.1),
        inset 0 9px 18px rgba(255, 255, 255, 0.08);
    }

    .sidebar::-webkit-scrollbar-thumb {
      border: 4px solid transparent;
      border-radius: 999px;
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(255, 255, 255, 0.58) 22%, rgba(192, 132, 252, 0.52) 58%, rgba(251, 113, 133, 0.42)) padding-box,
        linear-gradient(180deg, rgba(255, 255, 255, 0.86), rgba(192, 132, 252, 0.22)) border-box;
      background-clip: padding-box, border-box;
      box-shadow:
        inset 1px 1px 0 rgba(255, 255, 255, 0.72),
        inset -1px -1px 0 rgba(80, 38, 132, 0.18),
        0 0 0 1px rgba(255, 255, 255, 0.16),
        0 8px 24px rgba(192, 132, 252, 0.28);
      backdrop-filter: blur(16px) saturate(1.4);
    }

    .sidebar::-webkit-scrollbar-thumb:hover {
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 1), rgba(255, 255, 255, 0.7) 22%, rgba(192, 132, 252, 0.68) 58%, rgba(251, 113, 133, 0.56)) padding-box,
        linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(192, 132, 252, 0.34)) border-box;
      background-clip: padding-box, border-box;
      box-shadow:
        inset 1px 1px 0 rgba(255, 255, 255, 0.86),
        inset -1px -1px 0 rgba(80, 38, 132, 0.2),
        0 0 0 1px rgba(255, 255, 255, 0.22),
        0 10px 28px rgba(192, 132, 252, 0.38);
    }

    [data-theme="light"] .sidebar {
      scrollbar-color: rgba(255, 255, 255, 0.88) rgba(128, 78, 191, 0.1);
    }

    [data-theme="light"] .sidebar::-webkit-scrollbar-track {
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.9), rgba(192, 132, 252, 0.1) 48%, rgba(251, 113, 133, 0.09)) padding-box,
        linear-gradient(180deg, rgba(255, 255, 255, 0.85), rgba(128, 78, 191, 0.1)) border-box;
      box-shadow:
        inset 0 0 0 1px rgba(80, 38, 132, 0.08),
        inset 0 9px 18px rgba(255, 255, 255, 0.42);
    }

    [data-theme="light"] .sidebar::-webkit-scrollbar-thumb {
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 1), rgba(255, 255, 255, 0.72) 24%, rgba(192, 132, 252, 0.46) 58%, rgba(251, 113, 133, 0.3)) padding-box,
        linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(128, 78, 191, 0.22)) border-box;
      background-clip: padding-box, border-box;
      box-shadow:
        inset 1px 1px 0 rgba(255, 255, 255, 0.92),
        inset -1px -1px 0 rgba(80, 38, 132, 0.14),
        0 8px 24px rgba(128, 78, 191, 0.2);
    }

    .sidebar::before {
      position: absolute;
      inset: 0;
      pointer-events: none;
      content: "";
      background:
        linear-gradient(124deg, transparent 0 62%, rgba(192, 132, 252, 0.08) 63% 63.7%, transparent 64%),
        linear-gradient(8deg, transparent 0 46%, rgba(251, 113, 133, 0.06) 47% 47.6%, transparent 48%);
    }

    .sidebar-inner {
      position: relative;
      z-index: 1;
      height: 100%;
      padding: 22px 18px 40px;
      overflow-x: hidden;
      overflow-y: auto;
      scrollbar-width: none;
    }

    .sidebar-inner::-webkit-scrollbar {
      width: 0;
      height: 0;
    }

    .sidebar-glass-scrollbar {
      position: absolute;
      top: 18px;
      right: 6px;
      bottom: 18px;
      z-index: 3;
      width: 8px;
      border: 1px solid rgba(255, 255, 255, 0.07);
      border-radius: 999px;
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.06), rgba(192, 132, 252, 0.035) 50%, rgba(251, 113, 133, 0.035)),
        rgba(255, 255, 255, 0.018);
      box-shadow:
        inset 1px 1px 0 rgba(255, 255, 255, 0.07),
        inset -1px -1px 0 rgba(80, 38, 132, 0.1),
        0 8px 18px rgba(0, 0, 0, 0.12);
      backdrop-filter: blur(20px) saturate(1.7);
      opacity: 0.34;
      pointer-events: none;
      transition: opacity 0.22s ease, width 0.22s ease, border-color 0.22s ease, box-shadow 0.22s ease;
    }

    .sidebar-glass-scrollbar::before {
      position: absolute;
      top: 6px;
      left: 2px;
      width: 2px;
      height: 42%;
      border-radius: 999px;
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.28), transparent);
      content: "";
    }

    .sidebar-glass-thumb {
      position: absolute;
      top: 0;
      left: 1px;
      width: 4px;
      min-height: 54px;
      border: 1px solid rgba(255, 255, 255, 0.16);
      border-radius: 999px;
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.44), rgba(255, 255, 255, 0.22) 24%, rgba(192, 132, 252, 0.28) 58%, rgba(251, 113, 133, 0.2)),
        rgba(255, 255, 255, 0.16);
      box-shadow:
        inset 1px 1px 0 rgba(255, 255, 255, 0.36),
        inset -1px -1px 0 rgba(80, 38, 132, 0.12),
        0 4px 12px rgba(192, 132, 252, 0.12);
      transform: translateY(var(--sidebar-scroll-thumb-y, 0));
      transition: width 0.22s ease, background 0.22s ease, border-color 0.22s ease, box-shadow 0.22s ease, opacity 0.22s ease;
    }

    .sidebar:hover .sidebar-glass-scrollbar,
    .sidebar.is-scrolling .sidebar-glass-scrollbar {
      width: 10px;
      border-color: rgba(255, 255, 255, 0.12);
      opacity: 1;
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.14), rgba(192, 132, 252, 0.07) 50%, rgba(251, 113, 133, 0.08)),
        rgba(255, 255, 255, 0.035);
      box-shadow:
        inset 1px 1px 0 rgba(255, 255, 255, 0.14),
        inset -1px -1px 0 rgba(80, 38, 132, 0.16),
        0 12px 28px rgba(0, 0, 0, 0.22);
    }

    .sidebar:hover .sidebar-glass-thumb,
    .sidebar.is-scrolling .sidebar-glass-thumb {
      width: 6px;
      border-color: rgba(255, 255, 255, 0.38);
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.95), rgba(255, 255, 255, 0.55) 24%, rgba(192, 132, 252, 0.54) 58%, rgba(251, 113, 133, 0.4)),
        rgba(255, 255, 255, 0.34);
      box-shadow:
        inset 1px 1px 0 rgba(255, 255, 255, 0.82),
        inset -1px -1px 0 rgba(80, 38, 132, 0.18),
        0 0 0 1px rgba(255, 255, 255, 0.12),
        0 8px 22px rgba(192, 132, 252, 0.32);
    }

    .page-glass-scrollbar {
      position: fixed;
      top: calc(var(--topbar-h) + 8px);
      right: 5px;
      bottom: 12px;
      z-index: 50;
      width: 8px;
      border: 1px solid rgba(255, 255, 255, 0.07);
      border-radius: 999px;
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.06), rgba(192, 132, 252, 0.035) 50%, rgba(251, 113, 133, 0.035)),
        rgba(255, 255, 255, 0.018);
      box-shadow:
        inset 1px 1px 0 rgba(255, 255, 255, 0.07),
        inset -1px -1px 0 rgba(80, 38, 132, 0.1),
        0 8px 18px rgba(0, 0, 0, 0.12);
      backdrop-filter: blur(20px) saturate(1.7);
      opacity: 0.34;
      pointer-events: none;
      transition: opacity 0.22s ease, width 0.22s ease, border-color 0.22s ease, box-shadow 0.22s ease;
    }

    .page-glass-thumb {
      position: absolute;
      top: 0;
      left: 1px;
      width: 4px;
      min-height: 54px;
      border: 1px solid rgba(255, 255, 255, 0.16);
      border-radius: 999px;
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.44), rgba(255, 255, 255, 0.22) 24%, rgba(192, 132, 252, 0.28) 58%, rgba(251, 113, 133, 0.2)),
        rgba(255, 255, 255, 0.16);
      box-shadow:
        inset 1px 1px 0 rgba(255, 255, 255, 0.36),
        inset -1px -1px 0 rgba(80, 38, 132, 0.12),
        0 4px 12px rgba(192, 132, 252, 0.12);
      transform: translateY(var(--page-scroll-thumb-y, 0));
      transition: width 0.22s ease, background 0.22s ease, border-color 0.22s ease, box-shadow 0.22s ease;
    }

    body.is-page-scrolling .page-glass-scrollbar,
    .page-glass-scrollbar:hover {
      width: 10px;
      border-color: rgba(255, 255, 255, 0.12);
      opacity: 1;
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.14), rgba(192, 132, 252, 0.07) 50%, rgba(251, 113, 133, 0.08)),
        rgba(255, 255, 255, 0.035);
      box-shadow:
        inset 1px 1px 0 rgba(255, 255, 255, 0.14),
        inset -1px -1px 0 rgba(80, 38, 132, 0.16),
        0 12px 28px rgba(0, 0, 0, 0.22);
    }

    body.is-page-scrolling .page-glass-thumb,
    .page-glass-scrollbar:hover .page-glass-thumb {
      width: 6px;
      border-color: rgba(255, 255, 255, 0.38);
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.95), rgba(255, 255, 255, 0.55) 24%, rgba(192, 132, 252, 0.54) 58%, rgba(251, 113, 133, 0.4)),
        rgba(255, 255, 255, 0.34);
      box-shadow:
        inset 1px 1px 0 rgba(255, 255, 255, 0.82),
        inset -1px -1px 0 rgba(80, 38, 132, 0.18),
        0 0 0 1px rgba(255, 255, 255, 0.12),
        0 8px 22px rgba(192, 132, 252, 0.32);
    }

    [data-theme="light"] .sidebar-glass-scrollbar {
      border-color: rgba(128, 78, 191, 0.08);
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.48), rgba(192, 132, 252, 0.055) 50%, rgba(251, 113, 133, 0.045)),
        rgba(255, 255, 255, 0.22);
      box-shadow:
        inset 1px 1px 0 rgba(255, 255, 255, 0.38),
        inset -1px -1px 0 rgba(80, 38, 132, 0.08),
        0 8px 18px rgba(128, 78, 191, 0.08);
    }

    [data-theme="light"] .sidebar-glass-thumb {
      border-color: rgba(255, 255, 255, 0.34);
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.64), rgba(255, 255, 255, 0.34) 24%, rgba(192, 132, 252, 0.26) 58%, rgba(251, 113, 133, 0.16)),
        rgba(255, 255, 255, 0.3);
    }

    [data-theme="light"] .sidebar:hover .sidebar-glass-scrollbar,
    [data-theme="light"] .sidebar.is-scrolling .sidebar-glass-scrollbar {
      border-color: rgba(128, 78, 191, 0.12);
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.72), rgba(192, 132, 252, 0.1) 50%, rgba(251, 113, 133, 0.08)),
        rgba(255, 255, 255, 0.42);
      box-shadow:
        inset 1px 1px 0 rgba(255, 255, 255, 0.72),
        inset -1px -1px 0 rgba(80, 38, 132, 0.08),
        0 12px 28px rgba(128, 78, 191, 0.12);
    }

    [data-theme="light"] .sidebar:hover .sidebar-glass-thumb,
    [data-theme="light"] .sidebar.is-scrolling .sidebar-glass-thumb {
      border-color: rgba(255, 255, 255, 0.72);
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 1), rgba(255, 255, 255, 0.72) 24%, rgba(192, 132, 252, 0.46) 58%, rgba(251, 113, 133, 0.28)),
        rgba(255, 255, 255, 0.56);
    }

    .side-mark {
      padding: 8px 8px 18px;
      border-bottom: 1px solid var(--border-ink);
      margin-bottom: 18px;
    }

    .side-kanji {
      display: block;
      font-family: "ZCOOL XiaoWei", serif;
      font-size: 31px;
      line-height: 1;
    }

    .side-meta {
      display: block;
      margin-top: 7px;
      color: var(--ink-muted);
      font-family: "JetBrains Mono", monospace;
      font-size: 10px;
      letter-spacing: 0.2em;
    }

    .section-title {
      margin: 18px 8px 10px;
      color: var(--ink-muted);
      font-family: "JetBrains Mono", monospace;
      font-size: 10px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
    }

    .side-collection {
      margin-bottom: 12px;
    }

    .collection-toggle {
      position: relative;
      display: grid;
      grid-template-columns: 20px minmax(0, 1fr) auto;
      gap: 6px;
      align-items: center;
      width: 100%;
      min-height: 44px;
      padding: 8px;
      border: 1px solid rgba(251, 247, 255, 0.08);
      border-radius: 8px;
      background:
        linear-gradient(135deg, rgba(251, 247, 255, 0.045), rgba(192, 132, 252, 0.035)),
        rgba(15, 13, 26, 0.42);
      color: var(--ink-white);
      text-align: left;
      transition: border-color 0.22s, background 0.22s, transform 0.22s var(--ease-spring);
    }

    .collection-toggle:hover,
    .collection-toggle[aria-expanded="true"] {
      transform: translateY(-1px);
      border-color: rgba(192, 132, 252, 0.34);
      background:
        linear-gradient(135deg, rgba(251, 247, 255, 0.07), rgba(192, 132, 252, 0.06)),
        rgba(15, 13, 26, 0.55);
    }

    .collection-title {
      display: grid;
      gap: 2px;
      min-width: 0;
    }

    .collection-title strong {
      font-size: 13px;
      font-weight: 500;
      line-height: 1.2;
    }

    .collection-title span {
      color: var(--ink-muted);
      font-family: "JetBrains Mono", monospace;
      font-size: 9px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .collection-twist {
      color: var(--ink-muted);
      font-family: "JetBrains Mono", monospace;
      transition: transform 0.22s ease;
    }

    .collection-toggle[aria-expanded="true"] .collection-twist {
      transform: rotate(90deg);
    }

    .side-collection-body {
      display: grid;
      gap: 5px;
      padding: 10px 0 2px;
    }

    .side-collection-body[hidden] {
      display: none;
    }

    .side-collection.is-muted {
      opacity: 0.72;
    }

    .category-root {
      margin-bottom: 5px;
    }

    .category-button,
    .subcat-button,
    .side-link {
      position: relative;
      isolation: isolate;
      display: grid;
      grid-template-columns: 20px minmax(0, 1fr) auto;
      align-items: center;
      width: 100%;
      min-height: 42px;
      padding: 7px 8px;
      border: 0;
      border-left: 2px solid transparent;
      border-radius: 0 8px 8px 0;
      background: transparent;
      color: var(--ink-muted);
      text-align: left;
      overflow: hidden;
      transition: color 0.22s ease, border-color 0.22s ease, text-shadow 0.22s ease;
    }

    .category-button::before,
    .subcat-button::before,
    .side-link::before {
      position: absolute;
      inset: 0;
      z-index: -1;
      pointer-events: none;
      content: "";
      background:
        linear-gradient(90deg, color-mix(in srgb, var(--cat-color, var(--ink-accent)), transparent 82%), transparent 78%);
      opacity: 0;
      transition: opacity 0.26s ease;
    }

    .category-button::after,
    .subcat-button::after,
    .side-link::after {
      position: absolute;
      inset: 0;
      z-index: -1;
      pointer-events: none;
      content: "";
      background:
        linear-gradient(90deg, color-mix(in srgb, var(--cat-color, var(--ink-accent)), transparent 66%), transparent 82%);
      opacity: 0;
    }

    .category-button > *,
    .subcat-button > *,
    .side-link > * {
      position: relative;
      z-index: 1;
    }

    .category-button {
      font-family: "ZCOOL XiaoWei", serif;
      font-size: 18px;
    }

    .category-button .en {
      display: block;
      margin-top: 1px;
      font-family: "JetBrains Mono", monospace;
      font-size: 9px;
      letter-spacing: 0.14em;
    }

    .category-button:hover,
    .category-button.is-active,
    .subcat-button:hover,
    .subcat-button.is-active,
    .side-link:hover,
    .side-link.is-active {
      border-left-color: var(--cat-color, var(--ink-accent));
      color: var(--ink-white);
      text-shadow: 0 0 14px color-mix(in srgb, var(--cat-color, var(--ink-accent)), transparent 35%);
    }

    .category-button:hover::before,
    .category-button.is-active::before,
    .subcat-button:hover::before,
    .subcat-button.is-active::before,
    .side-link:hover::before,
    .side-link.is-active::before {
      opacity: 1;
    }

    .category-button.is-pressing::after,
    .subcat-button.is-pressing::after,
    .side-link.is-pressing::after {
      animation: sidePressFade 0.42s ease-out both;
    }

    .twist {
      justify-self: end;
      font-family: "JetBrains Mono", monospace;
      font-size: 12px;
      transition: transform 0.24s ease;
    }

    .category-button[aria-expanded="true"] .twist {
      transform: rotate(90deg);
    }

    .subcat-list {
      max-height: 0;
      overflow: hidden;
      opacity: 0;
      transition: max-height 0.32s ease, opacity 0.22s ease;
    }

    .subcat-list.is-open {
      max-height: 300px;
      opacity: 1;
    }

    .subcat-button {
      grid-template-columns: 18px minmax(0, 1fr);
      min-height: 34px;
      padding-left: 24px;
      font-family: "JetBrains Mono", monospace;
      font-size: 12px;
      transform: translateX(-5px);
      opacity: 0;
    }

    .subcat-list.is-open .subcat-button {
      animation: subcatIn 0.28s ease both;
    }

    .utility-links {
      padding-top: 16px;
      border-top: 1px solid var(--border-ink);
      margin-top: 20px;
    }

    .side-link {
      grid-template-columns: 20px minmax(0, 1fr);
      font-family: "JetBrains Mono", monospace;
      font-size: 12px;
    }

    .side-link:disabled {
      cursor: default;
      opacity: 0.54;
    }

    .main {
      grid-column: 2;
      grid-row: 2;
      min-height: 100dvh;
      padding: calc(var(--topbar-h) + 22px) 26px 48px;
    }

    .filter-bar {
      display: flex;
      justify-content: space-between;
      gap: 16px;
      align-items: center;
      margin-bottom: 16px;
    }

    .breadcrumb {
      min-width: 0;
      color: var(--ink-muted);
      font-family: "JetBrains Mono", monospace;
      font-size: 12px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .active-filter {
      color: var(--ink-white);
      text-shadow: 0 0 14px rgba(192, 132, 252, 0.28);
    }

    .result-count {
      flex: 0 0 auto;
      color: var(--ink-muted);
      font-family: "JetBrains Mono", monospace;
      font-size: 12px;
    }

    .hot-strip {
      display: flex;
      gap: 10px;
      padding: 4px 0 18px;
      margin-bottom: 6px;
      overflow-x: auto;
      overflow-y: hidden;
      scroll-behavior: smooth;
      scrollbar-width: none;
    }

    .hot-strip::-webkit-scrollbar {
      display: none;
    }

    .hot-strip:hover {
      overscroll-behavior-inline: contain;
    }

    .hot-chip {
      flex: 0 0 auto;
      min-height: 36px;
      padding: 8px 13px;
      border: 1px solid var(--border-ink);
      border-radius: 999px;
      background: rgba(15, 13, 26, 0.58);
      color: var(--ink-muted);
      font-family: "JetBrains Mono", monospace;
      font-size: 11px;
      transition: color 0.2s, border-color 0.2s, transform 0.2s var(--ease-spring);
    }

    .hot-chip:hover,
    .hot-chip.is-active {
      transform: translateY(-2px);
      border-color: rgba(251, 113, 133, 0.42);
      color: var(--ink-white);
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 18px;
    }

    .site-card {
      position: relative;
      height: 236px;
      min-height: 236px;
      padding: 19px;
      border: 0.5px solid var(--border-ink);
      border-radius: 8px 12px 7px 14px;
      background:
        linear-gradient(140deg, rgba(237, 232, 245, 0.035), transparent 36%),
        url("data:image/svg+xml,%3Csvg viewBox='0 0 120 120' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='p'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='1.35' numOctaves='3'/%3E%3C/filter%3E%3Crect width='120' height='120' filter='url(%23p)' opacity='.22'/%3E%3C/svg%3E"),
        var(--bg-paper);
      box-shadow: 0 12px 40px rgba(0, 0, 0, 0.22);
      clip-path: polygon(0 2%, 98% 0, 100% 93%, 96% 100%, 3% 98%, 0 88%);
      transform: rotate(var(--r, 0deg));
      transition: transform 0.25s var(--ease-spring), border-color 0.25s, box-shadow 0.25s;
      animation: cardIn 0.5s ease both;
      animation-delay: var(--d, 0.2s);
      cursor: pointer;
      overflow: hidden;
    }

    .site-card:nth-child(3n + 1) { --r: -0.28deg; }
    .site-card:nth-child(3n + 2) { --r: 0.22deg; }
    .site-card:nth-child(3n + 3) { --r: -0.08deg; }

    .site-card:hover,
    .site-card:focus-visible,
    .site-card.is-pulsing {
      transform: translateY(-3px) rotate(var(--r, 0deg));
      border-color: color-mix(in srgb, var(--cat-color, var(--ink-accent)), white 22%);
      box-shadow:
        0 22px 54px rgba(0, 0, 0, 0.38),
        0 0 0 2px color-mix(in srgb, var(--cat-color, var(--ink-accent)), transparent 12%),
        0 0 24px color-mix(in srgb, var(--cat-color, var(--ink-accent)), transparent 8%),
        0 0 64px color-mix(in srgb, var(--cat-color, var(--ink-accent)), transparent 16%),
        0 0 118px color-mix(in srgb, var(--cat-color, var(--ink-accent)), transparent 28%),
        0 0 150px rgba(251, 191, 36, 0.34);
    }

    .site-card:focus-visible {
      outline: 2px solid rgba(251, 191, 36, 0.78);
      outline-offset: 4px;
    }

    .site-card::before {
      position: absolute;
      top: 18px;
      left: 14px;
      width: 4px;
      height: 4px;
      border-radius: 99px;
      background: var(--cat-color, var(--ink-accent));
      box-shadow: 0 0 12px var(--cat-color, var(--ink-accent));
      content: "";
    }

    .site-card.is-pulsing::after {
      position: absolute;
      inset: -8px;
      border: 1px solid rgba(251, 191, 36, 0.72);
      border-radius: 14px;
      content: "";
      animation: discoverRing 1.1s ease-out both;
    }

    .site-card:hover::after,
    .site-card:focus-visible::after {
      position: absolute;
      inset: -12px;
      pointer-events: none;
      border: 1px solid color-mix(in srgb, var(--cat-color, var(--ink-accent)), white 26%);
      border-radius: 16px;
      content: "";
      filter: blur(4px);
      opacity: 0.95;
    }

    .card-head {
      display: flex;
      align-items: flex-start;
      gap: 14px;
      padding-left: 11px;
      margin-bottom: 12px;
    }

    .site-favicon {
      width: 36px;
      height: 36px;
      border-radius: 6px;
      flex-shrink: 0;
      object-fit: contain;
    }

    .card-head > div {
      min-width: 0;
    }

    .site-name {
      margin: 0;
      color: var(--ink-white);
      font-size: 16px;
      font-weight: 500;
      line-height: 1.35;
      transition: color 0.25s;
    }

    .site-card:hover .site-name {
      color: var(--ink-accent);
    }

    .domain {
      display: inline-flex;
      max-width: 100%;
      margin-top: 3px;
      color: var(--ink-muted);
      font-family: "JetBrains Mono", monospace;
      font-size: 11px;
      text-decoration: underline;
      text-decoration-color: transparent;
      text-underline-offset: 3px;
      transition: color 0.2s, text-decoration-color 0.2s;
    }

    .domain:hover,
    .domain:focus-visible {
      color: var(--ink-gold);
      text-decoration-color: currentColor;
    }

    .desc {
      display: -webkit-box;
      min-height: 42px;
      margin: 0 0 16px;
      overflow: hidden;
      color: var(--ink-muted);
      font-size: 13px;
      font-weight: 300;
      -webkit-box-orient: vertical;
      -webkit-line-clamp: 2;
    }

    .tags {
      display: flex;
      flex-wrap: nowrap;
      gap: 7px;
      height: 28px;
      margin-bottom: 12px;
      overflow-x: auto;
      overflow-y: hidden;
      scroll-behavior: smooth;
      scrollbar-width: none;
    }

    .tags::-webkit-scrollbar {
      display: none;
    }

    .tag {
      display: inline-flex;
      align-items: center;
      min-height: 22px;
      padding: 2px 8px;
      border: 1px solid var(--tag-border, #33334433);
      border-radius: 999px;
      background: var(--tag-bg, #1f1f2e);
      color: var(--tag-text, var(--ink-muted));
      font-family: "JetBrains Mono", monospace;
      font-size: 10px;
      line-height: 1;
      white-space: nowrap;
    }

    .card-actions {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-top: auto;
    }

    .card-action {
      display: inline-grid;
      place-items: center;
      min-width: 40px;
      height: 40px;
      padding: 0 13px;
      border: 1px solid var(--border-ink);
      border-radius: 8px;
      background: rgba(8, 7, 16, 0.34);
      color: var(--ink-muted);
      font-family: "JetBrains Mono", monospace;
      transition: color 0.2s, border-color 0.2s, transform 0.2s var(--ease-spring);
    }

    .card-action:hover,
    .card-action.is-saved {
      transform: translateY(-2px);
      border-color: rgba(251, 191, 36, 0.5);
      color: var(--ink-gold);
    }

    .site-link {
      min-width: 76px;
    }

    .favorite-toggle {
      width: 40px;
      padding: 0;
    }

    .site-dialog {
      width: min(96vw, 1120px);
      padding: 0;
      border: 1px solid rgba(192, 132, 252, 0.28);
      border-radius: 14px;
      background:
        linear-gradient(140deg, rgba(237, 232, 245, 0.06), transparent 38%),
        var(--bg-paper);
      color: var(--ink-white);
      box-shadow: 0 28px 90px rgba(0, 0, 0, 0.42), 0 0 54px rgba(192, 132, 252, 0.18);
      overflow: visible;
    }

    .site-dialog::backdrop {
      background: rgba(8, 7, 16, 0.68);
      backdrop-filter: blur(10px);
    }

    .game-dialog {
      width: min(94vw, 980px);
      padding: 0;
      border: 1px solid rgba(251, 191, 36, 0.26);
      border-radius: 14px;
      background:
        linear-gradient(140deg, rgba(251, 191, 36, 0.08), transparent 38%),
        var(--bg-paper);
      color: var(--ink-white);
      box-shadow: 0 28px 90px rgba(0, 0, 0, 0.44), 0 0 54px rgba(251, 191, 36, 0.13);
      overflow: hidden;
    }

    .game-dialog::backdrop {
      background: rgba(8, 7, 16, 0.72);
      backdrop-filter: blur(10px);
    }

    .game-window {
      display: grid;
      grid-template-rows: auto 1fr;
      min-height: min(72vh, 620px);
    }

    .game-window-bar {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 40px;
      gap: 12px;
      align-items: center;
      padding: 12px 14px;
      border-bottom: 1px solid var(--border-ink);
      background: rgba(8, 7, 16, 0.28);
    }

    .game-window-title {
      margin: 0;
      font-family: "JetBrains Mono", monospace;
      font-size: 13px;
    }

    .game-close {
      display: inline-grid;
      place-items: center;
      width: 40px;
      height: 40px;
      border: 1px solid var(--border-ink);
      border-radius: 8px;
      background: rgba(8, 7, 16, 0.34);
      color: var(--ink-muted);
    }

    .game-close:hover {
      border-color: rgba(251, 113, 133, 0.5);
      color: var(--ink-coral);
    }

    .game-frame {
      width: 100%;
      height: min(64vh, 560px);
      border: 0;
      background: #f7f7f7;
    }

    .site-detail {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(260px, 0.72fr) 0;
      gap: 18px;
      padding: 22px;
      transition: grid-template-columns 0.28s ease;
    }

    .site-detail.has-relation-panel {
      grid-template-columns: minmax(0, 1fr) minmax(260px, 0.72fr) minmax(260px, 0.62fr);
    }

    .detail-main {
      min-width: 0;
    }

    .detail-top {
      display: grid;
      grid-template-columns: 48px minmax(0, 1fr) 40px;
      gap: 12px;
      align-items: start;
    }

    .detail-favicon {
      width: 44px;
      height: 44px;
      border-radius: 10px;
      object-fit: contain;
      background: rgba(251, 247, 255, 0.04);
    }

    .detail-title {
      margin: 0;
      font-size: 22px;
      line-height: 1.22;
    }

    .detail-domain {
      margin-top: 4px;
      color: var(--ink-muted);
      font-family: "JetBrains Mono", monospace;
      font-size: 12px;
      overflow-wrap: anywhere;
    }

    .detail-close {
      display: inline-grid;
      place-items: center;
      width: 40px;
      height: 40px;
      border: 1px solid var(--border-ink);
      border-radius: 8px;
      background: rgba(8, 7, 16, 0.34);
      color: var(--ink-muted);
    }

    .detail-close:hover {
      border-color: rgba(251, 113, 133, 0.5);
      color: var(--ink-coral);
    }

    .detail-desc {
      margin: 20px 0 18px;
      color: var(--ink-muted);
      font-size: 14px;
    }

    .detail-meta {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
      margin-bottom: 18px;
    }

    .detail-meta-item {
      padding: 10px 12px;
      border: 1px solid var(--border-ink);
      border-radius: 8px;
      background: rgba(8, 7, 16, 0.22);
    }

    .detail-meta-label {
      display: block;
      color: var(--ink-muted);
      font-family: "JetBrains Mono", monospace;
      font-size: 10px;
      text-transform: uppercase;
    }

    .detail-meta-value {
      display: block;
      margin-top: 3px;
      font-size: 13px;
    }

    .detail-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 20px;
    }

    .detail-map {
      position: relative;
      min-width: 0;
      padding: 16px;
      border: 1px solid var(--border-ink);
      border-radius: 10px;
      background:
        radial-gradient(circle at 50% 30%, rgba(192, 132, 252, 0.16), transparent 56%),
        rgba(8, 7, 16, 0.22);
      overflow: hidden;
    }

    .detail-map::before {
      position: absolute;
      inset: 18px;
      pointer-events: none;
      border: 1px dashed rgba(192, 132, 252, 0.18);
      border-radius: 999px;
      content: "";
    }

    .map-title {
      position: relative;
      z-index: 1;
      margin: 0 0 14px;
      color: var(--ink-muted);
      font-family: "JetBrains Mono", monospace;
      font-size: 11px;
      text-transform: uppercase;
    }

    .map-center {
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: 34px minmax(0, 1fr);
      gap: 10px;
      align-items: center;
      padding: 11px;
      border: 1px solid color-mix(in srgb, var(--cat-color, var(--ink-accent)), transparent 32%);
      border-radius: 10px;
      background: rgba(25, 22, 37, 0.74);
      box-shadow: 0 0 26px color-mix(in srgb, var(--cat-color, var(--ink-accent)), transparent 72%);
    }

    .map-center img,
    .map-node img {
      width: 34px;
      height: 34px;
      border-radius: 8px;
      object-fit: contain;
      background: rgba(251, 247, 255, 0.04);
    }

    .map-center-name,
    .map-node-name {
      display: block;
      min-width: 0;
      overflow: hidden;
      color: var(--ink-white);
      font-size: 13px;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .map-center-role,
    .map-node-role {
      display: block;
      margin-top: 2px;
      color: var(--ink-muted);
      font-family: "JetBrains Mono", monospace;
      font-size: 10px;
      text-transform: uppercase;
    }

    .map-groups {
      position: relative;
      z-index: 1;
      display: grid;
      gap: 10px;
      margin-top: 14px;
    }

    .map-actions {
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: 1fr;
      gap: 8px;
      margin-top: 14px;
    }

    .map-action {
      min-width: 0;
      min-height: 40px;
      padding: 8px 11px;
      border: 1px solid rgba(192, 132, 252, 0.16);
      border-radius: 8px;
      background: rgba(15, 13, 26, 0.46);
      color: var(--ink-white);
      text-align: left;
      transition: background 0.22s, color 0.22s, box-shadow 0.22s;
    }

    .map-action:hover,
    .map-action.is-active {
      background: rgba(192, 132, 252, 0.14);
      color: var(--ink-white);
      box-shadow: inset 0 0 0 1px rgba(251, 191, 36, 0.18), 0 0 24px rgba(192, 132, 252, 0.14);
    }

    .map-action-label {
      display: block;
      font-size: 12px;
    }

    .map-action-count {
      display: block;
      margin-top: 2px;
      margin-left: 0;
      color: var(--ink-muted);
      font-family: "JetBrains Mono", monospace;
      font-size: 10px;
    }

    .relation-panel {
      position: relative;
      display: grid;
      grid-template-rows: auto 1fr;
      min-width: 0;
      max-height: min(72vh, 580px);
      padding: 15px;
      border: 1px solid rgba(192, 132, 252, 0.22);
      border-radius: 12px;
      background:
        radial-gradient(circle at 12% 8%, rgba(251, 191, 36, 0.08), transparent 44%),
        linear-gradient(180deg, rgba(25, 22, 37, 0.9), rgba(15, 13, 26, 0.84)),
        rgba(8, 7, 16, 0.22);
      box-shadow: inset 0 0 0 1px rgba(251, 247, 255, 0.035), 0 0 40px rgba(192, 132, 252, 0.12);
      opacity: 0;
      visibility: hidden;
      overflow: hidden;
      pointer-events: none;
      transform: translateX(-8px);
      transition: opacity 0.22s ease, transform 0.28s ease, visibility 0.22s;
    }

    .relation-panel::before {
      position: absolute;
      top: 18px;
      bottom: 18px;
      left: -10px;
      width: 1px;
      background: linear-gradient(180deg, transparent, rgba(251, 191, 36, 0.38), rgba(192, 132, 252, 0.28), transparent);
      content: "";
    }

    .site-detail.has-relation-panel .relation-panel {
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
      transform: translateX(0);
    }

    .relation-panel-head {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 34px;
      gap: 12px;
      align-items: center;
      margin-bottom: 12px;
    }

    .relation-panel-title {
      margin: 0;
      color: var(--ink-white);
      font-size: 14px;
      line-height: 1.2;
    }

    .relation-panel-close {
      display: inline-grid;
      place-items: center;
      width: 34px;
      height: 34px;
      border: 1px solid var(--border-ink);
      border-radius: 8px;
      background: rgba(8, 7, 16, 0.34);
      color: var(--ink-muted);
    }

    .relation-panel-list {
      display: grid;
      align-content: start;
      gap: 9px;
      min-height: 0;
      overflow-y: auto;
      scrollbar-width: thin;
    }

    .map-group {
      display: grid;
      gap: 7px;
    }

    .map-group-label {
      color: var(--ink-muted);
      font-family: "JetBrains Mono", monospace;
      font-size: 10px;
      text-transform: uppercase;
    }

    .map-node {
      display: grid;
      grid-template-columns: 34px minmax(0, 1fr) auto;
      gap: 9px;
      align-items: center;
      min-height: 48px;
      padding: 8px 10px;
      border: 1px solid rgba(192, 132, 252, 0.16);
      border-radius: 9px;
      background:
        linear-gradient(135deg, rgba(237, 232, 245, 0.045), transparent 45%),
        rgba(15, 13, 26, 0.58);
      color: inherit;
      text-align: left;
      transition: transform 0.22s var(--ease-spring), border-color 0.22s, box-shadow 0.22s;
    }

    .map-node:hover {
      transform: translateY(-2px);
      border-color: rgba(251, 191, 36, 0.48);
      box-shadow: 0 0 28px rgba(192, 132, 252, 0.18);
    }

    .map-node-arrow {
      color: var(--ink-gold);
      font-family: "JetBrains Mono", monospace;
      font-size: 12px;
    }

    .map-empty {
      position: relative;
      z-index: 1;
      margin: 14px 0 0;
      color: var(--ink-muted);
      font-size: 12px;
    }

    .detail-actions {
      display: flex;
      gap: 10px;
      align-items: center;
    }

    .detail-link,
    .detail-favorite {
      display: inline-flex;
      justify-content: center;
      align-items: center;
      min-height: 44px;
      border: 1px solid var(--border-ink);
      border-radius: 8px;
      font-family: "JetBrains Mono", monospace;
      font-size: 12px;
    }

    .detail-link {
      flex: 1;
      background: rgba(192, 132, 252, 0.14);
      color: var(--ink-white);
    }

    .detail-favorite {
      width: 52px;
      background: rgba(8, 7, 16, 0.34);
      color: var(--ink-muted);
    }

    .detail-favorite.is-saved {
      border-color: rgba(251, 191, 36, 0.5);
      color: var(--ink-gold);
    }

    /* Refined detail modal */
    .site-dialog {
      width: min(94vw, 1080px);
      max-height: min(86dvh, 760px);
      scrollbar-color: rgba(255, 255, 255, 0.28) rgba(255, 255, 255, 0.025);
      scrollbar-width: thin;
      border: 1px solid rgba(251, 247, 255, 0.12);
      border-radius: 18px;
      background:
        linear-gradient(135deg, rgba(251, 247, 255, 0.08), rgba(192, 132, 252, 0.04) 34%, transparent 64%),
        linear-gradient(180deg, rgba(25, 22, 37, 0.98), rgba(13, 11, 22, 0.98));
      box-shadow:
        0 34px 110px rgba(0, 0, 0, 0.58),
        0 0 0 1px rgba(251, 191, 36, 0.08),
        0 0 72px rgba(192, 132, 252, 0.2);
      overflow: hidden;
      opacity: 0;
      transform: translateY(18px) scale(0.975);
    }

    .site-dialog[open] {
      animation: detailDialogIn 0.28s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
    }

    .site-dialog[open].is-closing {
      animation: detailDialogOut 0.2s ease-in forwards;
    }

    .site-dialog::before {
      position: absolute;
      inset: 0;
      pointer-events: none;
      content: "";
      background:
        radial-gradient(circle at 9% 8%, rgba(251, 191, 36, 0.13), transparent 24rem),
        radial-gradient(circle at 92% 20%, rgba(192, 132, 252, 0.18), transparent 26rem),
        repeating-linear-gradient(0deg, transparent 0 6px, rgba(251, 247, 255, 0.035) 7px, transparent 8px);
      opacity: 0.9;
    }

    .site-dialog::backdrop {
      background:
        radial-gradient(circle at 50% 24%, rgba(192, 132, 252, 0.16), transparent 32rem),
        rgba(7, 6, 13, 0.74);
      backdrop-filter: blur(14px) saturate(1.1);
    }

    .site-detail {
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: minmax(420px, 0.9fr) minmax(440px, 1.1fr);
      gap: 16px;
      max-height: inherit;
      padding: 16px;
      overflow-x: hidden;
      overflow-y: auto;
      transition: grid-template-columns 0.28s ease;
    }

    .site-detail.has-relation-panel {
      grid-template-columns: minmax(420px, 0.9fr) minmax(440px, 1.1fr);
    }

    .detail-main,
    .detail-map,
    .relation-panel {
      border: 1px solid rgba(251, 247, 255, 0.1);
      border-radius: 14px;
      background:
        linear-gradient(145deg, rgba(251, 247, 255, 0.07), rgba(251, 247, 255, 0.025) 42%, rgba(8, 7, 16, 0.16)),
        rgba(12, 10, 20, 0.58);
      box-shadow: inset 0 1px 0 rgba(251, 247, 255, 0.06);
    }

    .detail-main {
      display: grid;
      grid-template-rows: auto minmax(170px, auto) auto auto auto;
      min-width: 0;
      padding: 24px;
    }

    .detail-top {
      grid-template-columns: 64px minmax(0, 1fr) 44px;
      gap: 14px;
      align-items: center;
    }

    .detail-favicon {
      width: 64px;
      height: 64px;
      border: 1px solid rgba(251, 247, 255, 0.1);
      border-radius: 14px;
      background:
        linear-gradient(145deg, rgba(251, 247, 255, 0.11), rgba(251, 247, 255, 0.03)),
        rgba(15, 13, 26, 0.74);
      box-shadow: 0 14px 36px rgba(0, 0, 0, 0.26);
    }

    .detail-title {
      font-family: "Noto Sans SC", system-ui, -apple-system, sans-serif;
      font-size: clamp(26px, 3.2vw, 38px);
      font-weight: 600;
      line-height: 1.12;
      text-shadow: 0 0 26px rgba(192, 132, 252, 0.22);
    }

    .detail-domain {
      margin-top: 8px;
      color: rgba(251, 191, 36, 0.82);
      font-size: 12px;
    }

    .detail-close {
      width: 44px;
      height: 44px;
      border-color: rgba(251, 247, 255, 0.12);
      border-radius: 12px;
      background: rgba(8, 7, 16, 0.56);
      font-size: 18px;
      transition: transform 0.2s var(--ease-spring), border-color 0.2s, color 0.2s, background 0.2s;
    }

    .detail-close:hover {
      transform: translateY(-1px);
      background: rgba(251, 113, 133, 0.1);
    }

    .detail-desc {
      min-height: 150px;
      margin: 26px 0 22px;
      padding: 18px 18px 20px;
      border: 1px solid rgba(251, 247, 255, 0.08);
      border-radius: 14px;
      background:
        linear-gradient(145deg, rgba(251, 247, 255, 0.055), rgba(251, 247, 255, 0.018)),
        rgba(8, 7, 16, 0.22);
      color: rgba(251, 247, 255, 0.78);
      font-size: 16px;
      line-height: 1.85;
    }

    .detail-meta {
      gap: 12px;
      margin-bottom: 18px;
    }

    .detail-meta-item {
      min-height: 82px;
      padding: 13px 14px;
      border-color: rgba(251, 247, 255, 0.1);
      border-radius: 12px;
      background: rgba(251, 247, 255, 0.035);
    }

    .detail-meta-label {
      color: rgba(251, 247, 255, 0.48);
      letter-spacing: 0.08em;
    }

    .detail-meta-value {
      margin-top: 6px;
      color: var(--ink-white);
      font-size: 14px;
    }

    .detail-tags {
      margin-bottom: 22px;
    }

    .detail-actions {
      position: sticky;
      bottom: 0;
      z-index: 2;
      display: grid;
      grid-template-columns: minmax(0, 1fr) 52px;
      gap: 10px;
      padding-top: 14px;
      margin-top: auto;
      background: linear-gradient(180deg, transparent, rgba(12, 10, 20, 0.95) 34%);
    }

    .detail-link,
    .detail-favorite {
      min-height: 52px;
      border-radius: 12px;
      transition: transform 0.2s var(--ease-spring), border-color 0.2s, box-shadow 0.2s, background 0.2s;
    }

    .detail-link {
      border-color: rgba(192, 132, 252, 0.28);
      background:
        linear-gradient(135deg, rgba(192, 132, 252, 0.3), rgba(251, 191, 36, 0.12)),
        rgba(192, 132, 252, 0.12);
      box-shadow: 0 14px 34px rgba(0, 0, 0, 0.2), 0 0 28px rgba(192, 132, 252, 0.12);
    }

    .detail-link:hover,
    .detail-favorite:hover {
      transform: translateY(-2px);
      border-color: rgba(251, 191, 36, 0.5);
      box-shadow: 0 18px 42px rgba(0, 0, 0, 0.28), 0 0 30px rgba(251, 191, 36, 0.14);
    }

    .detail-favorite {
      width: 52px;
      background: rgba(8, 7, 16, 0.46);
      font-size: 16px;
    }

    .detail-map {
      padding: 18px;
      overflow: hidden;
    }

    .detail-map::before {
      inset: 24px;
      border-color: rgba(251, 191, 36, 0.15);
      opacity: 0.9;
    }

    .map-title {
      margin-bottom: 16px;
      color: rgba(251, 247, 255, 0.56);
      letter-spacing: 0.08em;
    }

    .map-center {
      grid-template-columns: 42px minmax(0, 1fr);
      padding: 13px;
      border-radius: 13px;
      background: rgba(25, 22, 37, 0.78);
    }

    .map-center img,
    .map-node img {
      width: 42px;
      height: 42px;
      border-radius: 11px;
    }

    .map-actions {
      gap: 10px;
      margin-top: 16px;
    }

    .map-action {
      min-height: 54px;
      padding: 10px 12px;
      border-color: rgba(251, 247, 255, 0.1);
      border-radius: 12px;
      background: rgba(251, 247, 255, 0.035);
    }

    .map-action:hover,
    .map-action.is-active {
      background:
        linear-gradient(135deg, rgba(192, 132, 252, 0.16), rgba(251, 191, 36, 0.07)),
        rgba(15, 13, 26, 0.56);
    }

    .map-action-label {
      font-size: 13px;
      font-weight: 600;
    }

    .relation-panel {
      display: none;
      padding: 16px;
      transform: translateX(-12px) scale(0.98);
    }

    .site-detail.has-relation-panel .relation-panel {
      display: grid;
      transform: translateX(0) scale(1);
    }

    .relation-panel-close {
      width: 38px;
      height: 38px;
      border-radius: 10px;
    }

    .map-node {
      min-height: 58px;
      border-radius: 12px;
      background: rgba(251, 247, 255, 0.04);
    }

    .relationship-map {
      display: grid;
      grid-template-rows: auto 1fr;
      gap: 14px;
    }

    .relationship-map::before {
      display: none;
    }

    .relationship-board {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(172px, 0.55fr);
      gap: 14px;
      min-height: 430px;
    }

    .flow-lane {
      position: relative;
      display: grid;
      grid-template-rows: minmax(92px, auto) 34px minmax(92px, auto) 34px minmax(92px, auto);
      gap: 8px;
      min-width: 0;
    }

    .flow-lane::before {
      position: absolute;
      top: 86px;
      bottom: 86px;
      left: 24px;
      width: 1px;
      background: linear-gradient(180deg, rgba(251, 191, 36, 0.2), rgba(192, 132, 252, 0.56), rgba(134, 239, 172, 0.2));
      content: "";
    }

    .flow-group,
    .current-group,
    .alternative-group {
      position: relative;
      z-index: 1;
      display: grid;
      gap: 10px;
      padding: 12px;
      border: 1px solid rgba(251, 247, 255, 0.1);
      border-radius: 14px;
      background:
        linear-gradient(145deg, rgba(251, 247, 255, 0.06), rgba(251, 247, 255, 0.02)),
        rgba(10, 9, 18, 0.54);
    }

    .flow-group.is-upstream {
      border-color: rgba(251, 191, 36, 0.22);
    }

    .flow-group.is-downstream {
      border-color: rgba(52, 211, 153, 0.18);
    }

    .flow-label {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr);
      gap: 8px 10px;
      align-items: center;
    }

    .flow-icon {
      display: inline-grid;
      place-items: center;
      width: 28px;
      height: 28px;
      border: 1px solid rgba(251, 247, 255, 0.1);
      border-radius: 8px;
      background: rgba(251, 247, 255, 0.05);
      color: var(--ink-gold);
      font-family: "JetBrains Mono", monospace;
      font-size: 13px;
    }

    .flow-label strong {
      display: block;
      font-size: 15px;
      line-height: 1.2;
    }

    .flow-label em {
      display: block;
      margin-top: 2px;
      color: rgba(251, 247, 255, 0.48);
      font-family: "JetBrains Mono", monospace;
      font-size: 10px;
      font-style: normal;
      text-transform: uppercase;
    }

    .flow-nodes,
    .alternative-nodes {
      display: grid;
      gap: 8px;
    }

    .flow-node-empty {
      min-height: 54px;
      display: grid;
      place-items: center;
      border: 1px dashed rgba(251, 247, 255, 0.1);
      border-radius: 12px;
      color: rgba(251, 247, 255, 0.46);
      font-size: 12px;
    }

    .flow-arrow {
      position: relative;
      z-index: 1;
      display: grid;
      place-items: center;
      color: rgba(251, 191, 36, 0.9);
      font-family: "JetBrains Mono", monospace;
      font-size: 16px;
      text-shadow: 0 0 18px rgba(251, 191, 36, 0.26);
    }

    .current-group {
      border-color: rgba(192, 132, 252, 0.42);
      background:
        radial-gradient(circle at 24% 20%, rgba(192, 132, 252, 0.18), transparent 16rem),
        rgba(18, 15, 30, 0.84);
      box-shadow: 0 0 36px rgba(192, 132, 252, 0.16);
    }

    .current-tool-node {
      display: grid;
      grid-template-columns: 48px minmax(0, 1fr);
      gap: 12px;
      align-items: center;
      padding: 13px;
      border: 1px solid rgba(192, 132, 252, 0.44);
      border-radius: 14px;
      background: rgba(15, 13, 26, 0.72);
    }

    .current-tool-node.is-arriving {
      animation: currentToolArrive 0.52s ease-out both;
    }

    .current-tool-node img {
      width: 48px;
      height: 48px;
      border-radius: 12px;
      object-fit: contain;
      background: rgba(251, 247, 255, 0.04);
    }

    .current-tool-name {
      display: block;
      font-size: 18px;
      font-weight: 700;
      line-height: 1.25;
    }

    .current-tool-role {
      display: block;
      margin-top: 3px;
      color: rgba(251, 247, 255, 0.52);
      font-size: 12px;
    }

    .alternative-group {
      align-content: start;
      border-color: rgba(251, 113, 133, 0.18);
    }

    .alternative-group .flow-icon {
      color: var(--ink-coral);
    }

    .relationship-map .map-node {
      min-height: 54px;
      padding: 8px 10px;
      border-color: rgba(251, 247, 255, 0.1);
    }

    .relationship-map .map-node:hover {
      border-color: rgba(251, 191, 36, 0.42);
    }

    /* Fixed single-window detail layout */
    .site-dialog {
      width: min(90vw, 960px);
      height: min(82dvh, 630px);
      max-height: min(82dvh, 630px);
    }

    /* 弹窗打开时禁止背景滚动 */
    body:has(.site-dialog[open]) {
      overflow: hidden;
    }

    /* 详情弹窗内的纵向滚动区使用同款轻玻璃滚动条 */
    .site-dialog .graph-node-list,
    .site-dialog .alt-icon-list {
      overflow-y: auto;
      scrollbar-color: rgba(255, 255, 255, 0.26) rgba(255, 255, 255, 0.025);
      scrollbar-width: thin;
    }
    .site-dialog .graph-node-list::-webkit-scrollbar,
    .site-dialog .alt-icon-list::-webkit-scrollbar {
      width: 10px;
    }
    .site-dialog .detail-copy .detail-desc {
      overflow-y: auto;
      scrollbar-color: rgba(255, 255, 255, 0.24) rgba(255, 255, 255, 0.025);
      scrollbar-width: thin;
    }
    .site-dialog .detail-copy .detail-desc::-webkit-scrollbar {
      width: 10px;
    }

    .site-detail,
    .site-detail.has-relation-panel {
      display: block;
      width: 100%;
      height: 100%;
      padding: 0;
      overflow: hidden;
    }

    .detail-window {
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-rows: 86px minmax(0, 1fr) 70px;
      width: 100%;
      height: 100%;
      min-height: 0;
    }

    .detail-window.is-switching {
      animation: detailContentSwitch 0.32s ease-out both;
    }

    .detail-window .detail-top {
      display: grid;
      grid-template-columns: 56px minmax(0, 1fr) 42px;
      gap: 13px;
      align-items: center;
      min-height: 86px;
      padding: 16px 20px 13px;
      border-bottom: 1px solid rgba(251, 247, 255, 0.09);
      background:
        linear-gradient(90deg, rgba(192, 132, 252, 0.1), transparent 58%),
        rgba(8, 7, 16, 0.18);
    }

    .detail-content {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      gap: 0;
      min-height: 0;
      scrollbar-color: rgba(255, 255, 255, 0.28) rgba(255, 255, 255, 0.025);
      scrollbar-width: thin;
    }

    .detail-copy {
      display: grid;
      grid-template-rows: minmax(0, 1fr) auto auto;
      min-width: 0;
      min-height: 0;
      padding: 20px;
      border-right: 1px solid rgba(251, 247, 255, 0.08);
    }

    .detail-copy .detail-desc {
      min-height: 0;
      height: 100%;
      margin: 0;
      overflow-y: auto;
      color: rgba(251, 247, 255, 0.84);
      font-size: 16px;
      line-height: 1.8;
    }

    .detail-copy .detail-meta {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      margin: 14px 0 12px;
    }

    .detail-copy .detail-meta-item {
      min-height: 70px;
    }

    .detail-copy .detail-tags {
      max-height: 76px;
      margin: 0;
      overflow-y: auto;
    }

    .detail-graph {
      display: grid;
      grid-template-rows: 32px minmax(0, 1fr);
      min-width: 0;
      min-height: 0;
      padding: 12px 18px 16px;
    }

    .graph-head {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      align-items: start;
      color: rgba(251, 247, 255, 0.58);
      font-family: "JetBrains Mono", monospace;
      font-size: 11px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .graph-head span {
      color: var(--ink-gold);
    }

    .graph-head small {
      max-width: 300px;
      color: rgba(251, 247, 255, 0.42);
      font-size: 10px;
      line-height: 1.5;
      letter-spacing: 0;
      text-align: right;
      text-transform: none;
    }

    .graph-body {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 88px;
      gap: 10px;
      min-height: 0;
    }

    .graph-flow {
      position: relative;
      display: grid;
      grid-template-rows: minmax(72px, 0.64fr) 28px 82px 28px minmax(170px, 1.7fr);
      gap: 7px;
      min-height: 0;
    }

    .graph-flow::before {
      position: absolute;
      top: 24px;
      bottom: 24px;
      left: 20px;
      width: 1px;
      background: linear-gradient(180deg, rgba(251, 191, 36, 0.34), rgba(192, 132, 252, 0.58), rgba(52, 211, 153, 0.32));
      content: "";
    }

    .graph-section,
    .graph-current,
    .graph-alt-rail {
      position: relative;
      min-width: 0;
      min-height: 0;
      border: 1px solid rgba(251, 247, 255, 0.1);
      border-radius: 14px;
      background:
        linear-gradient(145deg, rgba(251, 247, 255, 0.055), rgba(251, 247, 255, 0.018)),
        rgba(8, 7, 16, 0.34);
    }

    .graph-section {
      display: grid;
      grid-template-columns: 130px minmax(0, 1fr);
      gap: 10px;
      padding: 12px;
    }

    .graph-upstream {
      border-color: rgba(251, 191, 36, 0.2);
    }

    /* 上游一般只有一个节点，不滚动，自动撑开 */
    .graph-upstream .graph-node-list {
      overflow: visible;
      scrollbar-width: none;
    }

    .graph-downstream {
      border-color: rgba(52, 211, 153, 0.18);
    }

    .graph-section-label {
      display: grid;
      align-content: center;
      gap: 4px;
      min-width: 0;
    }

    .graph-section-label strong {
      color: var(--ink-white);
      font-size: 18px;
      line-height: 1.15;
    }

    .graph-section-label span {
      color: rgba(251, 247, 255, 0.48);
      font-size: 11px;
      line-height: 1.45;
    }

    .graph-node-list,
    .graph-alt-list {
      display: grid;
      gap: 8px;
      min-height: 0;
      overflow-y: auto;
    }

    .graph-downstream .graph-node-list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      align-content: start;
      padding: 6px 0 0 16px;
    }

    .graph-downstream {
      grid-template-columns: 1fr;
      grid-template-rows: auto minmax(0, 1fr);
      gap: 6px;
    }

    .graph-downstream .graph-section-label {
      grid-template-columns: auto minmax(0, 1fr);
      align-items: baseline;
      align-content: center;
      gap: 8px;
    }

    .graph-downstream .graph-section-label strong {
      font-size: 16px;
    }

    .graph-downstream .graph-section-label span {
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .graph-connector {
      position: relative;
      z-index: 1;
      display: flex;
      justify-content: center;
      gap: 10px;
      align-items: center;
      color: rgba(251, 191, 36, 0.86);
      font-family: "JetBrains Mono", monospace;
      font-size: 12px;
    }

    .graph-connector b {
      font-size: 17px;
      line-height: 1;
    }

    .graph-current {
      display: grid;
      align-items: center;
      padding: 12px;
      border-color: rgba(192, 132, 252, 0.42);
      background:
        radial-gradient(circle at 18% 30%, rgba(192, 132, 252, 0.2), transparent 18rem),
        rgba(18, 15, 30, 0.82);
    }

    .detail-graph .current-tool-node {
      min-height: 58px;
      padding: 9px 11px;
    }

    .graph-alt-rail {
      display: grid;
      grid-template-rows: auto minmax(0, 1fr);
      align-self: start;
      max-height: 100%;
      gap: 8px;
      padding: 8px;
      border-color: rgba(251, 113, 133, 0.2);
      background:
        linear-gradient(180deg, rgba(251, 113, 133, 0.055), rgba(251, 247, 255, 0.018)),
        rgba(8, 7, 16, 0.28);
    }

    .alt-rail-title {
      min-height: 28px;
      display: inline-flex;
      justify-content: center;
      align-items: center;
      padding: 0 6px;
      border: 1px solid rgba(251, 113, 133, 0.16);
      border-radius: 9px;
      background: rgba(251, 113, 133, 0.075);
      color: rgba(251, 247, 255, 0.78);
      font-size: 12px;
      font-weight: 700;
      text-align: center;
      letter-spacing: 0;
      white-space: nowrap;
    }

    .alt-icon-list {
      display: grid;
      grid-template-columns: 1fr;
      align-content: start;
      justify-content: center;
      gap: 8px;
      min-height: 0;
      overflow-y: auto;
      padding-top: 6px;
    }

    .alt-icon-node {
      display: grid;
      place-items: center;
      width: 68px;
      height: 68px;
      border: 1px solid rgba(251, 247, 255, 0.1);
      border-radius: 12px;
      background: rgba(251, 247, 255, 0.045);
      transition: transform 0.2s var(--ease-spring), border-color 0.2s, box-shadow 0.2s;
    }

    .alt-icon-node:hover,
    .alt-icon-node:focus-visible {
      transform: translateY(-2px);
      border-color: rgba(251, 113, 133, 0.45);
      box-shadow: 0 0 22px rgba(251, 113, 133, 0.16);
    }

    .alt-icon-node img {
      width: 44px;
      height: 44px;
      border-radius: 8px;
      object-fit: contain;
    }

    .alt-icon-empty {
      display: grid;
      place-items: center;
      width: 68px;
      height: 68px;
      border: 1px dashed rgba(251, 247, 255, 0.1);
      border-radius: 7px;
      color: rgba(251, 247, 255, 0.42);
      font-size: 10px;
    }

    .detail-graph .map-node {
      min-height: 52px;
      height: 52px;
      padding: 7px 9px;
      border-radius: 12px;
      background: rgba(251, 247, 255, 0.045);
    }

    .graph-downstream .map-node {
      grid-template-columns: 30px minmax(0, 1fr) 14px;
      min-height: 44px;
      height: 44px;
      padding: 6px 8px;
      gap: 7px;
    }

    .detail-graph .map-node img {
      width: 34px;
      height: 34px;
    }

    .graph-downstream .map-node img {
      width: 30px;
      height: 30px;
      border-radius: 9px;
    }

    .detail-graph .map-node-name {
      font-size: 13px;
    }

    .graph-downstream .map-node-name {
      font-size: 12px;
    }

    .detail-graph .map-node-role {
      font-size: 9px;
    }

    .graph-downstream .map-node-role {
      display: none;
    }

    .graph-downstream .map-node-arrow {
      font-size: 10px;
    }

    .flow-node-empty {
      min-height: 52px;
      height: 52px;
    }

    .detail-window .detail-actions {
      position: static;
      display: grid;
      grid-template-columns: minmax(0, 1fr) 58px;
      gap: 11px;
      min-height: 70px;
      padding: 11px 19px 15px;
      border-top: 1px solid rgba(251, 247, 255, 0.09);
      background:
        linear-gradient(180deg, rgba(13, 11, 22, 0.7), rgba(13, 11, 22, 0.98));
    }

    .detail-window .detail-link,
    .detail-window .detail-favorite {
      min-height: 44px;
    }

    @media (max-width: 980px) {
      .site-dialog {
        width: min(94vw, 760px);
        height: min(88dvh, 760px);
        max-height: min(88dvh, 760px);
      }

      .site-detail,
      .site-detail.has-relation-panel {
        display: block;
      }

      .detail-content {
        grid-template-columns: 1fr;
        grid-template-rows: auto auto;
        overflow-x: hidden;
        overflow-y: auto;
      }

      .detail-copy {
        grid-template-rows: auto auto auto;
        min-height: auto;
        border-right: 0;
        border-bottom: 1px solid rgba(251, 247, 255, 0.08);
      }

      .detail-copy .detail-desc {
        height: auto;
        max-height: 180px;
      }

      .detail-window {
