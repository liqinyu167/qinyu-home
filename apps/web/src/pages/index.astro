      localStorage.setItem("manga_nav_favorites", JSON.stringify([...state.favorites]));
      els.favoriteCount.textContent = state.favorites.size;
    }

    function domainFromUrl(url) {
      try {
        return new URL(url).hostname.replace(/^www\./, "");
      } catch {
        return url.replace(/^https?:\/\//, "").split("/")[0];
      }
    }

    function faviconPath(site) {
      if (site.icon) return `assets/favicons/${site.icon}`;
      return `assets/favicons/${site.url.replace(/^https?:\/\//, "").split("/")[0].replace(/\./g, "_")}.png`;
    }

    // ─── Favicon lazy loading via IntersectionObserver ───
    const faviconObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const img = entry.target;
          if (img.dataset.src) {
            img.src = img.dataset.src;
            img.removeAttribute("data-src");
          }
          faviconObserver.unobserve(img);
        }
      });
    }, { rootMargin: "120px" });

    function observeFavicons(container) {
      const imgs = (container instanceof Node ? container : document).querySelectorAll(".site-favicon[data-src]");
      imgs.forEach(img => faviconObserver.observe(img));
    }

    function getCategoryLabel(id) {
      const category = state.categories.find((item) => item.id === id);
      return category ? `${category.label} ${category.en}` : "全部";
    }

    function getSiteCategory(site) {
      return site.category || (site.primarySection ? "tools" : "");
    }

    function getSiteSections(site) {
      return site.sections || (site.subcategory ? [site.subcategory] : []);
    }

    function getSubcategoryLabel(categoryId, subcategoryId) {
      const category = state.categories.find((item) => item.id === categoryId);
      return category?.children?.find((child) => child.id === subcategoryId)?.label || "未分类";
    }

    function getPrimarySectionLabel(site) {
      const categoryId = getSiteCategory(site);
      const sectionId = site.primarySection || site.subcategory;
      return getSubcategoryLabel(categoryId, sectionId);
    }

    function getSiteById(id) {
      return state.sites.find((site) => site.id === id);
    }

    function renderTag(tag) {
      const style = tagStyles[tag] || ["#1f1f2e", "#7a718f", "#33334433"];
      return `<span class="tag" style="--tag-bg:${style[0]};--tag-text:${style[1]};--tag-border:${style[2]}">${tag}</span>`;
    }

    const relationLabels = {
      upstream: "上游",
      downstream: "下游",
      alternatives: "替代"
    };

    function relatedSitesFor(site, key) {
      return (site.relations?.[key] || []).map(getSiteById).filter(Boolean);
    }

    function renderMapNode(relatedSite) {
      return `
        <button class="map-node" type="button" data-id="${relatedSite.id}" aria-label="查看 ${relatedSite.name}">
          <img src="${faviconPath(relatedSite)}" alt="" onerror="this.style.visibility='hidden'">
          <span>
            <span class="map-node-name">${relatedSite.name}</span>
            <span class="map-node-role">${getPrimarySectionLabel(relatedSite)}</span>
          </span>
          <span class="map-node-arrow" aria-hidden="true">↗</span>
        </button>
      `;
    }

    function renderRelationshipNodes(items) {
      return items.length
        ? items.map(renderMapNode).join("")
        : `<div class="flow-node-empty">暂无维护</div>`;
    }

    function renderAlternativeIconNodes(items) {
      return items.length
        ? items.map((relatedSite) => `
          <button class="alt-icon-node" type="button" data-id="${relatedSite.id}" aria-label="查看替代工具 ${relatedSite.name}" title="${relatedSite.name}">
            <img src="${faviconPath(relatedSite)}" alt="" onerror="this.style.visibility='hidden'">
          </button>
        `).join("")
        : `<div class="alt-icon-empty">无</div>`;
    }

    function renderRelationMap(site) {
      const upstream = relatedSitesFor(site, "upstream");
      const downstream = relatedSitesFor(site, "downstream");
      const alternatives = relatedSitesFor(site, "alternatives");

      return `
        <section class="detail-graph" data-site-id="${site.id}" aria-label="上下游关系图">
          <div class="graph-head">
            <span>关系图</span>
            <small>上游提供能力，当前工具承接并衍生到下游</small>
          </div>

          <div class="graph-body">
            <div class="graph-flow">
              <section class="graph-section graph-upstream">
                <div class="graph-section-label">
                  <strong>上游</strong>
                  <span>来源 / 底层能力 / 母公司</span>
                </div>
                <div class="graph-node-list">${renderRelationshipNodes(upstream)}</div>
              </section>

              <div class="graph-connector" aria-hidden="true">
                <span>提供能力给</span>
                <b>↓</b>
              </div>

              <section class="graph-current">
                <div class="current-tool-node">
                  <img src="${faviconPath(site)}" alt="" onerror="this.style.visibility='hidden'">
                  <span>
                    <span class="current-tool-name">${site.name}</span>
                    <span class="current-tool-role">当前工具 / ${getPrimarySectionLabel(site)}</span>
                  </span>
                </div>
              </section>

              <div class="graph-connector" aria-hidden="true">
                <span>衍生 / 承接到</span>
                <b>↓</b>
              </div>

              <section class="graph-section graph-downstream">
                <div class="graph-section-label">
                  <strong>下游</strong>
                  <span>产品 / 入口 / 配套服务</span>
                </div>
                <div class="graph-node-list">${renderRelationshipNodes(downstream)}</div>
              </section>
            </div>

            <aside class="graph-alt-rail" aria-label="替代工具">
              <div class="alt-rail-title">替代</div>
              <div class="alt-icon-list">${renderAlternativeIconNodes(alternatives)}</div>
            </aside>
          </div>
        </section>
      `;
    }

