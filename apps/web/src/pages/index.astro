    function openRelationDrawer(button) {
      const detail = button.closest(".site-detail");
      const map = detail.querySelector(".detail-map");
      const relation = button.dataset.relation;
      const site = getSiteById(map.dataset.siteId);
      if (!detail || !map || !relation || !site) return;
      const title = detail.querySelector(".relation-panel-title");
      const list = detail.querySelector(".relation-panel-list");
      const relatedSites = relatedSitesFor(site, relation);
      map.querySelectorAll(".map-action").forEach((item) => {
        item.classList.toggle("is-active", item === button);
      });
      title.textContent = relationLabels[relation];
      list.innerHTML = relatedSites.length
        ? relatedSites.map(renderMapNode).join("")
        : `<p class="map-empty">这里还没有维护内容。</p>`;
      detail.classList.add("has-relation-panel");
    }

    function closeRelationDrawer(target) {
      const detail = target.closest(".site-detail");
      if (!detail) return;
      const map = detail.querySelector(".detail-map");
      detail.classList.remove("has-relation-panel");
      map.querySelectorAll(".map-action").forEach((item) => item.classList.remove("is-active"));
    }

    function compareSites(a, b) {
      const weightDiff = Number(b.weight || 0) - Number(a.weight || 0);
      if (weightDiff) return weightDiff;
      return String(a.name || "").localeCompare(String(b.name || ""), "en", { sensitivity: "base" });
    }

    function getFilteredSites() {
      const query = state.search.trim().toLowerCase();
      return state.sites.filter((site) => {
        const siteCategory = getSiteCategory(site);
        const siteSections = getSiteSections(site);
        const matchesCategory = state.activeCategory === "all" || siteCategory === state.activeCategory;
        const matchesSubcategory = !state.activeSubcategory || siteSections.includes(state.activeSubcategory);
        const haystack = [
          site.name,
          site.description,
          site.url,
          site.type,
          site.primarySection,
          ...(site.sections || []),
          ...(site.capabilities || []),
          ...(site.tags || [])
        ].join(" ").toLowerCase();
        const matchesSearch = !query || haystack.includes(query);
        const matchesFavorite = !state.favoritesOnly || state.favorites.has(site.id);
        return matchesCategory && matchesSubcategory && matchesSearch && matchesFavorite;
      }).sort(compareSites);
    }

    function renderTree() {
      els.tree.innerHTML = "";
      state.categories.forEach((category) => {
        const root = document.createElement("div");
        root.className = "category-root";
        root.style.setProperty("--cat-color", categoryColors[category.id] || "var(--ink-accent)");

        const button = document.createElement("button");
        button.type = "button";
        button.className = "category-button";
        button.dataset.category = category.id;
        button.setAttribute("aria-expanded", String(state.expanded.has(category.id)));
        button.innerHTML = `<span aria-hidden="true">◈</span><span>${category.label}<span class="en">${category.en}</span></span><span class="twist" aria-hidden="true">▸</span>`;
        button.classList.toggle("is-active", state.activeView === "website-index" && state.activeCategory === category.id && !state.activeSubcategory && !state.favoritesOnly);
        button.addEventListener("click", () => {
          playSidePress(button);
          if (state.expanded.has(category.id)) state.expanded.delete(category.id);
          else state.expanded.add(category.id);
          state.activeCategory = category.id;
          state.activeSubcategory = "";
          state.favoritesOnly = false;
          state.activeView = "website-index";
          render();
          closeMobileSidebar();
        });
        root.appendChild(button);

        const list = document.createElement("div");
        list.className = `subcat-list ${state.expanded.has(category.id) ? "is-open" : ""}`;
        list.dataset.category = category.id;
        const children = category.children && category.children.length ? category.children : [
          { id: `${category.id}-loading`, label: "等待 API 子分类" }
        ];
        children.forEach((child, index) => {
          const childButton = document.createElement("button");
          childButton.type = "button";
          childButton.className = "subcat-button";
          childButton.dataset.category = category.id;
          childButton.dataset.subcategory = child.id;
          childButton.style.animationDelay = `${index * 30}ms`;
          childButton.innerHTML = `<span aria-hidden="true">◆</span><span>${child.label}</span>`;
          childButton.classList.toggle("is-active", state.activeView === "website-index" && state.activeSubcategory === child.id);
          childButton.disabled = child.id.endsWith("-loading");
          childButton.addEventListener("click", () => {
            playSidePress(childButton);
            state.activeCategory = category.id;
            state.activeSubcategory = child.id;
            state.favoritesOnly = false;
            state.activeView = "website-index";
            render();
            closeMobileSidebar();
          });
          list.appendChild(childButton);
        });
        root.appendChild(list);
        els.tree.appendChild(root);
      });
    }

    function updateTreeState() {
      els.tree.querySelectorAll(".category-button").forEach((button) => {
        const categoryId = button.dataset.category;
        const isExpanded = state.expanded.has(categoryId);
        button.setAttribute("aria-expanded", String(isExpanded));
        button.classList.toggle("is-active", state.activeView === "website-index" && state.activeCategory === categoryId && !state.activeSubcategory && !state.favoritesOnly);
      });

      els.tree.querySelectorAll(".subcat-list").forEach((list) => {
        list.classList.toggle("is-open", state.expanded.has(list.dataset.category));
      });

      els.tree.querySelectorAll(".subcat-button").forEach((button) => {
        const isCurrentSubcategory = state.activeCategory === button.dataset.category && state.activeSubcategory === button.dataset.subcategory;
        button.classList.toggle("is-active", state.activeView === "website-index" && isCurrentSubcategory && !state.favoritesOnly);
      });
    }

    function playSidePress(button) {
      if (!button) return;
      button.classList.remove("is-pressing");
      void button.offsetWidth;
      button.classList.add("is-pressing");
      window.setTimeout(() => button.classList.remove("is-pressing"), 450);
    }

    function updateSidebarScrollbar() {
      const scroller = els.sidebarInner;
      const track = els.sidebarScrollbar;
      const thumb = els.sidebarScrollThumb;
      if (!scroller || !track || !thumb) return;

      const maxScroll = scroller.scrollHeight - scroller.clientHeight;
      track.hidden = false;
      const trackHeight = track.clientHeight;
      if (maxScroll <= 2 || trackHeight <= 0) {
        track.hidden = true;
        return;
      }

      const thumbHeight = Math.max(54, Math.round((scroller.clientHeight / scroller.scrollHeight) * trackHeight));
      const maxThumbY = Math.max(0, trackHeight - thumbHeight - 2);
      const thumbY = Math.round((scroller.scrollTop / maxScroll) * maxThumbY);
      thumb.style.height = `${thumbHeight}px`;
      thumb.style.setProperty("--sidebar-scroll-thumb-y", `${thumbY}px`);
    }

    function setSidebarScrolling() {
      els.sidebar.classList.add("is-scrolling");
      window.clearTimeout(sidebarScrollTimer);
      sidebarScrollTimer = window.setTimeout(() => {
        els.sidebar.classList.remove("is-scrolling");
      }, 620);
    }

    function updatePageScrollbar() {
      const track = els.pageScrollbar;
      const thumb = els.pageScrollThumb;
      if (!track || !thumb) return;

      const doc = document.documentElement;
      const scrollTop = window.scrollY || doc.scrollTop || 0;
      const maxScroll = Math.max(0, doc.scrollHeight - window.innerHeight);
      track.hidden = false;
      const trackHeight = track.clientHeight;
      if (maxScroll <= 2 || trackHeight <= 0) {
        track.hidden = true;
        return;
      }

      const thumbHeight = Math.max(54, Math.round((window.innerHeight / doc.scrollHeight) * trackHeight));
      const maxThumbY = Math.max(0, trackHeight - thumbHeight - 2);
      const thumbY = Math.round((scrollTop / maxScroll) * maxThumbY);
      thumb.style.height = `${thumbHeight}px`;
      thumb.style.setProperty("--page-scroll-thumb-y", `${thumbY}px`);
    }

    function setPageScrolling() {
      document.body.classList.add("is-page-scrolling");
      window.clearTimeout(pageScrollTimer);
      pageScrollTimer = window.setTimeout(() => {
        document.body.classList.remove("is-page-scrolling");
      }, 620);
    }

