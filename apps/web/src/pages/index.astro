    // ─── Model Arena Helper Functions ───
    function getModelXCoordinate(model, xAxisMode, sortedActiveModels) {
      // Find the index of the model in the pre-sorted activeModels array
      const idx = sortedActiveModels.findIndex(m => m.id === model.id);
      const N = sortedActiveModels.length;

      // Calculate rank ratio: 0.0 (left-most / newest / cheapest) to 1.0 (right-most)
      const r = N > 1 ? idx / (N - 1) : 0;

      // Calculate virtual X using a power function:
      // This spreads the top 20% of models over the first page (0 to 100 units)
      // and compresses the remaining 80% of models over the second/third pages (100 to 260 units)
      const virtualX = Math.pow(r, 0.6) * 100 * (state.chartZoom || 2.6);

      // Compute scrolled X by subtracting current scroll offset
      const scrolledX = virtualX - (state.chartScrollOffset || 0);

      // Edge stacking / asymptotic clamping
      let displayedX;
      if (scrolledX >= 0 && scrolledX <= 100) {
        displayedX = 5 + (scrolledX / 100) * 90; // Linear display between [5%, 95%]
      } else if (scrolledX > 100) {
        const overflow = scrolledX - 100;
        const clampedX = 100 + 4 * (1 - Math.exp(-overflow / 20));
        displayedX = 5 + (clampedX / 100) * 90; // Stack on the right border: clamp in [95%, 98.6%]
      } else {
        const overflow = -scrolledX;
        const clampedX = 0 - 4 * (1 - Math.exp(-overflow / 20));
        displayedX = 5 + (clampedX / 100) * 90; // Stack on the left border: clamp in [1.4%, 5%]
      }

      return { displayedX, scrolledX };
    }

    function getModelYCoordinate(model, activeModels) {
      // Per-category scaling: strongest model → top (100%), weakest → bottom (0%)
      // Compute dynamic range from the active models in the current category
      const caps = (activeModels || []).map(m => m.capability || 0).filter(c => c > 0);
      const maxCap = caps.length ? Math.max(...caps) : 100;
      const minCap = caps.length ? Math.min(...caps) : 35;
      const range = maxCap - minCap || 1; // avoid divide by zero

      let capability = model.capability || 0;

      // ratio: 0.0 (weakest in category) to 1.0 (strongest in category)
      const ratio = (capability - minCap) / range;

      // Apply power curve (exponent 1.5) for balanced spread:
      // Top models get more spacing, bottom compress slightly
      // Maps to ~5% (top) to ~92% (bottom) of chart height
      return 92 - Math.pow(ratio, 1.5) * 87;
    }

    function getModelIcon(model) {
      if (model.channels?.official?.length) {
        const site = getSiteById(model.channels.official[0]);
        if (site) return faviconPath(site);
      }
      if (model.channels?.canvas?.length) {
        const site = getSiteById(model.channels.canvas[0]);
        if (site) return faviconPath(site);
      }
      if (model.channels?.api?.length) {
        const site = getSiteById(model.channels.api[0]);
        if (site) return faviconPath(site);
      }
      const brandIcons = {
        "openai": "assets/favicons/chatgpt_com.png",
        "anthropic": "assets/favicons/claude_ai.png",
        "google": "assets/favicons/gemini_google_com.png",
        "deepseek": "assets/favicons/chat_deepseek_com.png",
        "meta": "assets/favicons/meta_ai.png",
        "black-forest-labs": "assets/favicons/blackforestlabs_ai.png",
        "midjourney": "assets/favicons/www_midjourney_com.png",
        "runway": "assets/favicons/runwayml_com.png",
        "qwen": "assets/favicons/chat_qwen_ai.png",
        "kling": "assets/favicons/kling_kuaishou_com.png",
        "ideogram": "assets/favicons/ideogram_ai.png"
      };
      return brandIcons[model.brand] || "assets/favicons/huggingface_co.png";
    }

    function populateChannelPills(containerEl, siteIds) {
      containerEl.innerHTML = "";
      if (!siteIds || siteIds.length === 0) {
        containerEl.innerHTML = `<span class="channel-pill" style="opacity: 0.5; cursor: default; pointer-events: none;">暂未收录</span>`;
        return;
      }
      siteIds.forEach((sid) => {
        const site = getSiteById(sid);
        if (!site) return;
        const pill = document.createElement("button");
        pill.type = "button";
        pill.className = "channel-pill";

        pill.innerHTML = `
          <span class="channel-pill-fallback-icon" style="display:none; font-size:10px; margin-right:4px;">🌐</span>
          <img class="channel-pill-icon" src="${faviconPath(site)}" alt="" onerror="this.style.display='none'; this.previousElementSibling.style.display='inline-block';">
          <span>${site.name}</span>
        `;

        pill.addEventListener("click", () => {
          // Open the site detail modal directly
          openSiteDetail(site);
        });
        containerEl.appendChild(pill);
      });
    }

    function repositionModelPopover(capsuleEl) {
      if (els.modelPopover.hidden) return;

      const popoverWidth = els.modelPopover.offsetWidth || 290;
      const popoverHeight = els.modelPopover.offsetHeight || 280;

      const capsuleRect = capsuleEl.getBoundingClientRect();
      const containerEl = els.modelArenaSection.querySelector(".arena-chart-container");
      const containerRect = containerEl.getBoundingClientRect();

      // Calculate center of capsule (invariant under scale/transform)
      const centerX = capsuleRect.left + capsuleRect.width / 2;
      const centerY = capsuleRect.top + capsuleRect.height / 2;

      const centerXRel = centerX - containerRect.left;
      const centerYRel = centerY - containerRect.top;

      // Calculate the final active dimensions of the capsule (when zoomed to 1.05x of full size)
      const finalActiveWidth = (capsuleEl.offsetWidth / (state.capsuleSize || 1)) * 1.05;
      const finalActiveHeight = (capsuleEl.offsetHeight / (state.capsuleSize || 1)) * 1.05;

      // Calculate space available on all sides of the active capsule boundaries
      const spaceRight = containerRect.width - (centerXRel + finalActiveWidth / 2);
      const spaceLeft = centerXRel - finalActiveWidth / 2;
      const spaceBottom = containerRect.height - (centerYRel + finalActiveHeight / 2);
      const spaceTop = centerYRel - finalActiveHeight / 2;

      // Padding threshold (gap + screen margin)
      const thresholdHorizontal = popoverWidth + 27; // 12px gap + 15px margin

      let placement = 'right'; // default placement

      if (spaceRight >= thresholdHorizontal) {
        placement = 'right';
      } else if (spaceLeft >= thresholdHorizontal) {
        placement = 'left';
      } else {
        // Doesn't fit horizontally on either side (e.g., mobile or narrow viewports), place it vertically
        if (spaceBottom >= spaceTop) {
          placement = 'bottom';
        } else {
          placement = 'top';
        }
      }

      let left = 0;
      let top = 0;

      if (placement === 'right') {
        left = centerXRel + finalActiveWidth / 2 + 12;
        top = centerYRel - popoverHeight / 2;
      } else if (placement === 'left') {
        left = centerXRel - finalActiveWidth / 2 - popoverWidth - 12;
        top = centerYRel - popoverHeight / 2;
      } else if (placement === 'bottom') {
        left = centerXRel - popoverWidth / 2;
        top = centerYRel + finalActiveHeight / 2 + 12;
      } else if (placement === 'top') {
        left = centerXRel - popoverWidth / 2;
        top = centerYRel - finalActiveHeight / 2 - popoverHeight - 12;
      }

      // Clamp to container boundaries to ensure it never overflows
      const clampedLeft = Math.max(15, Math.min(left, containerRect.width - popoverWidth - 15));
      const clampedTop = Math.max(15, Math.min(top, containerRect.height - popoverHeight - 15));

      els.modelPopover.style.left = `${clampedLeft}px`;
      els.modelPopover.style.top = `${clampedTop}px`;
    }

    function openModelPopover(model, capsuleEl) {
      document.querySelectorAll(".model-capsule.active").forEach(c => c.classList.remove("active"));
      capsuleEl.classList.add("active");
      state.activeModelId = model.id;

      els.popoverModelName.textContent = model.name;
      if (model.open_source) {
        els.popoverHFBadge.hidden = false;
        els.popoverHFBadge.href = model.huggingface_url || "https://huggingface.co";
      } else {
        els.popoverHFBadge.hidden = true;
      }

      els.popoverCapability.textContent = `${model.capability}%`;
      if (state.xAxisMode === "price") {
        if (els.popoverXLabel) els.popoverXLabel.textContent = "🏷️ 价格";
        els.popoverXValue.textContent = model.price === 0 ? "免费" : `$${model.price}/M token`;
      } else {
        if (els.popoverXLabel) els.popoverXLabel.textContent = "📅 发布时间";
        els.popoverXValue.textContent = model.release_date || "未知";
      }

      populateChannelPills(els.channelOfficial, model.channels?.official);
      populateChannelPills(els.channelCanvas, model.channels?.canvas);
      populateChannelPills(els.channelApi, model.channels?.api);

      const wasHidden = els.modelPopover.hidden;
      if (wasHidden) {
        // Temporarily disable transition so it jumps to position instantly when opening
        els.modelPopover.style.transition = "none";
        els.modelPopover.hidden = false;
        repositionModelPopover(capsuleEl);
        // Force reflow
        els.modelPopover.offsetHeight;
        // Restore transition
        els.modelPopover.style.transition = "";
      } else {
        repositionModelPopover(capsuleEl);
      }

      els.modelPopover.classList.add("show");
    }

    function closeModelPopover() {
      els.modelPopover.classList.remove("show");
      document.querySelectorAll(".model-capsule.active").forEach(c => c.classList.remove("active"));
      state.activeModelId = null;
      setTimeout(() => {
        if (!state.activeModelId) {
          els.modelPopover.hidden = true;
        }
      }, 200);
    }

    function updateModelPositionsOnly() {
      // 1. Update grid background position
      if (els.chartGridBg) {
        const plotWidth = els.chartPlotArea.clientWidth || 1;
        // Background moves in opposite direction of scroll offset
        const bgPos = -state.chartScrollOffset * (plotWidth / 100);
        els.chartGridBg.style.backgroundPositionX = `${bgPos}px`;
      }

      // Update scrollbar thumb position
      if (els.chartScrollbarThumb) {
        const zoom = state.chartZoom || 2.6;
        const thumbWidthPercent = (1 / zoom) * 100;
        els.chartScrollbarThumb.style.width = `${thumbWidthPercent}%`;

        const maxScroll = Math.max(0.1, 100 * (zoom - 1));
        const thumbLeftPercent = (state.chartScrollOffset / maxScroll) * (100 - thumbWidthPercent);
        els.chartScrollbarThumb.style.left = `${thumbLeftPercent}%`;
      }

      // Synchronize zoom controls slider and labels
      const currentZoom = state.chartZoom || 2.6;
      if (els.chartZoomSlider) {
        els.chartZoomSlider.value = String(currentZoom);
      }
      if (els.chartZoomVal) {
        const typeText = currentZoom === 1.0 ? "纵览" : currentZoom === 2.6 ? "默认" : "细览";
        els.chartZoomVal.textContent = `${typeText} (${currentZoom.toFixed(1)}x)`;
      }

      // 2. Update each model capsule position and stacked states
      const activeModels = (state.models || []).filter(m => m.category === state.activeModelCategory);
      // Pre-sort activeModels as we do for rendering
      if (state.xAxisMode === "price") {
        activeModels.sort((a, b) => (a.price || 0) - (b.price || 0));
      } else {
        activeModels.sort((a, b) => {
          const dateA = a.release_date || "";
          const dateB = b.release_date || "";
          return dateB.localeCompare(dateA);
        });
      }

      activeModels.forEach((model) => {
        const capsule = els.chartPlotArea.querySelector(`.model-capsule[data-id="${model.id}"]`);
        if (!capsule) return;

        const { displayedX, scrolledX } = getModelXCoordinate(model, state.xAxisMode, activeModels);
        capsule.style.left = `${displayedX}%`;

        // Update stacked classes
        const isLeft = scrolledX < 0;
        const isRight = scrolledX > 100;
        const isStacked = isLeft || isRight;

        capsule.classList.toggle("is-stacked", isStacked);
        capsule.classList.toggle("is-stacked-left", isLeft);
        capsule.classList.toggle("is-stacked-right", isRight);
      });

      // 3. Update popover position if it's active and shown
      if (state.activeModelId) {
        const activeCapsule = els.chartPlotArea.querySelector(`.model-capsule[data-id="${state.activeModelId}"]`);
        if (activeCapsule) {
          repositionModelPopover(activeCapsule);
        }
      }
    }

    function renderModelArena() {
      // Toggle X-axis mode active states
      els.xModePrice.classList.toggle("active", state.xAxisMode === "price");
      els.xModeDate.classList.toggle("active", state.xAxisMode === "date");

      // Update axis labels
      if (state.xAxisMode === "price") {
        els.xAxisLabelLeft.textContent = "← 便宜 / 免费";
        els.xAxisLabelRight.textContent = "昂贵";
      } else {
        els.xAxisLabelLeft.textContent = "← 最新发布";
        els.xAxisLabelRight.textContent = "早期型号";
      }

      // Apply observation mode to container
      const container = els.modelArenaSection.querySelector(".arena-chart-container");
      if (container) {
        container.classList.toggle("observation-icon-only", state.observationMode === "icon-only");
      }

      // Apply capsule scale
      els.chartPlotArea.style.setProperty('--capsule-scale', String(state.capsuleSize));

      // Update top controls
      if (els.capsuleSizeSlider) {
        els.capsuleSizeSlider.value = String(state.capsuleSize);
      }
      if (els.capsuleSizeVal) {
        els.capsuleSizeVal.textContent = `${state.capsuleSize.toFixed(1)}x`;
      }
      if (els.viewModeStandard) {
        els.viewModeStandard.classList.toggle("active", state.observationMode === "standard");
      }
      if (els.viewModeIconOnly) {
        els.viewModeIconOnly.classList.toggle("active", state.observationMode === "icon-only");
      }

      // Clear plot area
      els.chartPlotArea.innerHTML = "";

      const activeModels = (state.models || []).filter(m => m.category === state.activeModelCategory);

      // Pre-sort activeModels as we do for coordinates ranking
      if (state.xAxisMode === "price") {
        activeModels.sort((a, b) => (a.price || 0) - (b.price || 0));
      } else {
        activeModels.sort((a, b) => {
          const dateA = a.release_date || "";
          const dateB = b.release_date || "";
          return dateB.localeCompare(dateA);
        });
      }

      activeModels.forEach((model) => {
        const yPercent = getModelYCoordinate(model, activeModels);
        const { displayedX } = getModelXCoordinate(model, state.xAxisMode, activeModels);

        const capsule = document.createElement("div");
        capsule.className = "model-capsule";
        if (state.activeModelId === model.id) {
          capsule.classList.add("active");
        }
        capsule.style.top = `${yPercent}%`;
        capsule.style.left = `${displayedX}%`;
        capsule.dataset.id = model.id;

        const iconUrl = getModelIcon(model);
        let hfEmoji = "";
        if (model.open_source) {
          hfEmoji = `<span class="capsule-hf-emoji" title="开源模型 (Hugging Face)" data-hf-url="${model.huggingface_url || 'https://huggingface.co'}">🤗</span>`;
        }

        capsule.innerHTML = `
          <img class="capsule-logo" src="${iconUrl}" alt="" onerror="this.src='assets/favicons/huggingface_co.png'">
          <span class="capsule-name">${model.name}</span>
          ${hfEmoji}
        `;

        capsule.addEventListener("click", (e) => {
          // If we recently dragged, do not trigger popover
          if (state.hasDragged) return;

          if (e.target.classList.contains("capsule-hf-emoji")) {
            e.stopPropagation();
            const url = e.target.dataset.hfUrl;
            window.open(url, "_blank", "noopener,noreferrer");
            return;
          }
          openModelPopover(model, capsule);
        });

        els.chartPlotArea.appendChild(capsule);
      });

      // Synchronize element positions with current scroll offset and set stacked states
      updateModelPositionsOnly();
    }

    function render() {
      if (state.activeView === "model-arena") {
        if (els.modelsToggle && els.modelsCollection) {
          els.modelsToggle.setAttribute("aria-expanded", "true");
          els.modelsCollection.hidden = false;
        }

        els.grid.style.display = "none";
        els.hotStrip.style.display = "none";
        els.modelArenaSection.hidden = false;
        els.modelArenaSection.style.display = "flex";

        renderModelArena();

        document.querySelectorAll(".model-category-btn").forEach((btn) => {
          const cat = btn.dataset.modelCategory;
          btn.classList.toggle("active", state.activeModelCategory === cat);
        });

        if (els.tree.childElementCount) updateTreeState();
        else renderTree();

        els.favoritesButton.classList.remove("is-active");
        els.sideFavorites.classList.remove("is-active");

        const modelCatLabel = state.activeModelCategory === "llm" ? "语言模型（LLM）" :
                              state.activeModelCategory === "text-to-image" ? "文生图" :
                              state.activeModelCategory === "image-editing" ? "图像编辑" :
                              state.activeModelCategory === "text-to-video" ? "文生视频" : "图生视频";
        els.activeFilter.textContent = `模型大比拼 / ${modelCatLabel}`;

        const activeModelsCount = (state.models || []).filter(m => m.category === state.activeModelCategory).length;
        els.resultCount.textContent = `${activeModelsCount} MODELS`;
        els.clear.classList.toggle("is-visible", Boolean(state.search));
      } else {
        // 退出个人模式
        document.body.classList.remove("personal-active");
        const ps = document.getElementById("personalSection");
        if (ps) ps.hidden = true;
        document.getElementById("toolbox").style.display = "";
        document.querySelectorAll(".side-link.is-active").forEach(b => b.classList.remove("is-active"));

        if (els.websitesToggle && els.websitesCollection) {
          els.websitesToggle.setAttribute("aria-expanded", "true");
          els.websitesCollection.hidden = false;
        }

        els.grid.style.display = "";
        els.hotStrip.style.display = "";
        els.modelArenaSection.hidden = true;
        els.modelArenaSection.style.display = "none";
        els.modelPopover.hidden = true;

        const sites = getFilteredSites();
        if (!els.grid.querySelector(".site-card, .empty-state")) buildCards();
        ensureCards(sites);
        filterCards(sites);
        renderHotStrip();
        if (els.tree.childElementCount) updateTreeState();
        else renderTree();

        document.querySelectorAll(".model-category-btn").forEach((btn) => {
          btn.classList.remove("active");
        });

        els.grid.querySelectorAll(".favorite-toggle").forEach((btn) => {
          btn.classList.toggle("is-saved", state.favorites.has(btn.dataset.id));
        });

        const label = state.favoritesOnly ? "收藏夹" : (state.activeCategory === "all" ? "全部" : getCategoryLabel(state.activeCategory));
        els.activeFilter.textContent = state.search ? `${label} / ${state.search}` : label;
        els.resultCount.textContent = `${sites.length} SITES`;
        els.clear.classList.toggle("is-visible", Boolean(state.search));
        els.favoritesButton.classList.toggle("is-active", state.favoritesOnly);
        els.sideFavorites.classList.toggle("is-active", state.favoritesOnly);
      }
      saveFavorites();
      window.requestAnimationFrame(updateSidebarScrollbar);
      window.requestAnimationFrame(updatePageScrollbar);
    }

    function closeMobileSidebar() {
      const isMobile = window.matchMedia("(max-width: 767px)").matches;
      els.sidebar.classList.remove("is-open");
      els.backdrop.classList.remove("is-open");
      if (isMobile) els.menuButton.setAttribute("aria-expanded", "false");
      else updateMenuButtonState();
    }

    function updateMenuButtonState() {
      const isMobile = window.matchMedia("(max-width: 767px)").matches;
      const isExpanded = isMobile
        ? els.sidebar.classList.contains("is-open")
        : !document.body.classList.contains("sidebar-collapsed");
      els.menuButton.setAttribute("aria-expanded", String(isExpanded));
    }

    function toggleFavorite(id) {
      if (state.favorites.has(id)) state.favorites.delete(id);
      else state.favorites.add(id);
      render();
    }

    async function loadData() {
      try {
        const response = await fetch(`${API_BASE}/sites`, { cache: "no-store" });
        if (!response.ok) throw new Error("sites.json not found");
        const data = await response.json();
        state.categories = data.categories && data.categories.length ? data.categories : MOCK_DATA.categories;
        state.sites = Array.isArray(data.sites) ? data.sites : FALLBACK_SITES;
        state.models = Array.isArray(data.models) ? data.models : [];
      } catch {
        state.categories = MOCK_DATA.categories;
        state.sites = FALLBACK_SITES;
        state.models = [];
      }
      render();
    }

    function bindEvents() {
      const hero = document.querySelector(".hero");
      const enterCover = document.querySelector(".hero-scroll");
      const topbar = document.querySelector(".topbar");
      let touchStartY = 0;

      function dismissHero({ instant = false } = {}) {
        if (!hero) return;
        document.body.classList.add("toolbox-open");
        hero.setAttribute("aria-hidden", "true");
        hero.inert = true;
        if (instant) {
          hero.hidden = true;
        } else {
          window.setTimeout(() => {
            if (document.body.classList.contains("toolbox-open")) hero.hidden = true;
          }, 560);
        }
        window.scrollTo(0, 0);
        window.requestAnimationFrame(updatePageScrollbar);
      }

      function restoreHero() {
        if (!hero) return;
        hero.hidden = false;
        hero.removeAttribute("aria-hidden");
        hero.inert = false;
        if (window.location.hash === "#toolbox") {
          history.replaceState(null, "", `${window.location.pathname}${window.location.search}`);
        }
        window.requestAnimationFrame(() => {
          document.body.classList.remove("toolbox-open");
          window.scrollTo(0, 0);
          updatePageScrollbar();
        });
      }

      if (window.location.hash === "#toolbox") {
        dismissHero({ instant: true });
      }

      window.addEventListener("wheel", (event) => {
        if (!hero || document.body.classList.contains("toolbox-open") || event.deltaY <= 0) return;
        event.preventDefault();
        dismissHero();
      }, { passive: false });

      els.hotStrip.addEventListener("wheel", (event) => {
        const overflow = els.hotStrip.scrollWidth - els.hotStrip.clientWidth;
        if (overflow <= 0) return;
        event.preventDefault();
        const delta = Math.abs(event.deltaX) > Math.abs(event.deltaY) ? event.deltaX : event.deltaY;
        els.hotStrip.scrollBy({ left: delta * 1.2, behavior: "smooth" });
      }, { passive: false });

      els.sidebarInner.addEventListener("scroll", () => {
        updateSidebarScrollbar();
        setSidebarScrolling();
      }, { passive: true });
      window.addEventListener("scroll", () => {
        updatePageScrollbar();
        setPageScrolling();
      }, { passive: true });
      window.addEventListener("resize", () => {
        updateSidebarScrollbar();
        updatePageScrollbar();
        updateMenuButtonState();
        if (state.activeView === "model-arena") {
          // If popover is open, reposition it relative to the resized viewport
          if (state.activeModelId) {
            const activeCapsule = document.querySelector(`.model-capsule[data-id="${state.activeModelId}"]`) as HTMLElement;
            if (activeCapsule) {
              repositionModelPopover(activeCapsule);
            }
          }
        }
      });

      els.modelsToggle.addEventListener("click", () => {
        const isOpen = els.modelsToggle.getAttribute("aria-expanded") === "true";
        els.modelsToggle.setAttribute("aria-expanded", String(!isOpen));
        els.modelsCollection.hidden = isOpen;
        if (!isOpen) {
          state.activeView = "model-arena";
          if (!state.activeModelCategory) {
            state.activeModelCategory = "llm";
          }
          render();
        } else {
          window.requestAnimationFrame(updateSidebarScrollbar);
        }
      });

      els.websitesToggle.addEventListener("click", () => {
        const isOpen = els.websitesToggle.getAttribute("aria-expanded") === "true";
        els.websitesToggle.setAttribute("aria-expanded", String(!isOpen));
        els.websitesCollection.hidden = isOpen;
        if (!isOpen) {
          state.activeView = "website-index";
          render();
        } else {
          window.requestAnimationFrame(updateSidebarScrollbar);
        }
      });

      const brandCopy = document.querySelector(".brand-copy");
      if (brandCopy) {
        brandCopy.addEventListener("click", () => {
          state.activeView = "website-index";
          state.activeCategory = "all";
          state.activeSubcategory = "";
          state.favoritesOnly = false;
          state.search = "";
          if (els.search) els.search.value = "";
          render();
          closeMobileSidebar();
        });
      }

      // 进入工具箱按钮 → 关闭封面，露出个人简介
      const heroScrollBtn = document.getElementById("heroScrollBtn");
      if (heroScrollBtn) {
        heroScrollBtn.addEventListener("click", () => {
          dismissHero();
        });
      }

      els.contentShelfToggle.addEventListener("click", () => {
        const isOpen = els.contentShelfToggle.getAttribute("aria-expanded") === "true";
        els.contentShelfToggle.setAttribute("aria-expanded", String(!isOpen));
        els.contentShelfCollection.hidden = isOpen;
        window.requestAnimationFrame(updateSidebarScrollbar);
      });

      els.grid.addEventListener("wheel", (event) => {
        const tagStrip = event.target.closest(".tags");
        if (!tagStrip) return;
        const overflow = tagStrip.scrollWidth - tagStrip.clientWidth;
        if (overflow <= 0) return;
        event.preventDefault();
        const delta = Math.abs(event.deltaX) > Math.abs(event.deltaY) ? event.deltaX : event.deltaY;
        tagStrip.scrollBy({ left: delta * 1.2, behavior: "smooth" });
      }, { passive: false });

      window.addEventListener("touchstart", (event) => {
        touchStartY = event.touches[0] ? event.touches[0].clientY : 0;
      }, { passive: true });

      window.addEventListener("touchmove", (event) => {
        if (!hero || document.body.classList.contains("toolbox-open")) return;
        const currentY = event.touches[0] ? event.touches[0].clientY : touchStartY;
        if (touchStartY - currentY > 26) {
          event.preventDefault();
          dismissHero();
        }
      }, { passive: false });

      window.addEventListener("keydown", (event) => {
        const enterKeys = ["ArrowDown", "PageDown", " "];
        const backKeys = ["ArrowUp", "PageUp"];
        if (!document.body.classList.contains("toolbox-open") && enterKeys.includes(event.key)) {
          event.preventDefault();
          dismissHero();
          return;
        }
        if (document.body.classList.contains("toolbox-open") && backKeys.includes(event.key)) {
          event.preventDefault();
          restoreHero();
        }
      });

      if (enterCover) {
        enterCover.addEventListener("click", (event) => {
          event.preventDefault();
          dismissHero();
        });
      }

      if (topbar) {
        topbar.addEventListener("wheel", (event) => {
          if (!hero || !document.body.classList.contains("toolbox-open") || event.deltaY >= 0) return;
          event.preventDefault();
          restoreHero();
        }, { passive: false });
      }

      els.search.addEventListener("input", (event) => {
        state.search = event.target.value;
        state.activeView = "website-index";
        render();
      });

      els.clear.addEventListener("click", () => {
        els.search.value = "";
        state.search = "";
        state.activeView = "website-index";
        els.search.focus();
        render();
      });

      els.grid.addEventListener("click", (event) => {
        const favoriteButton = event.target.closest(".favorite-toggle");
        if (favoriteButton) {
          toggleFavorite(favoriteButton.dataset.id);
          return;
        }
        if (event.target.closest("a, button")) return;
        const card = event.target.closest(".site-card");
        if (card) openSiteDetail(getSiteById(card.dataset.id));
      });

      els.grid.addEventListener("keydown", (event) => {
        if (!["Enter", " "].includes(event.key)) return;
        if (event.target.closest("a, button")) return;
        const card = event.target.closest(".site-card");
        if (!card) return;
        event.preventDefault();
        openSiteDetail(getSiteById(card.dataset.id));
      });

      els.siteDialog.addEventListener("click", (event) => {
        if (event.target === els.siteDialog) {
          closeSiteDetail();
          return;
        }
        const closeButton = event.target.closest(".detail-close");
        if (closeButton) {
          closeSiteDetail();
          return;
        }
        const favoriteButton = event.target.closest(".detail-favorite");
        if (favoriteButton) {
          toggleFavorite(favoriteButton.dataset.id);
          favoriteButton.classList.toggle("is-saved", state.favorites.has(favoriteButton.dataset.id));
          return;
        }
        const drawerClose = event.target.closest(".relation-panel-close");
        if (drawerClose) {
          closeRelationDrawer(drawerClose);
          return;
        }
        const relationButton = event.target.closest(".map-action");
        if (relationButton) {
          openRelationDrawer(relationButton);
          return;
        }
        const mapNode = event.target.closest(".map-node");
        if (mapNode) {
          openSiteDetail(getSiteById(mapNode.dataset.id));
          return;
        }
        const altIconNode = event.target.closest(".alt-icon-node");
        if (altIconNode) {
          openSiteDetail(getSiteById(altIconNode.dataset.id));
        }
      });

      els.siteDialog.addEventListener("cancel", (event) => {
        event.preventDefault();
        closeSiteDetail();
      });

      els.favoritesButton.addEventListener("click", () => {
        state.favoritesOnly = !state.favoritesOnly;
        state.activeCategory = "all";
        state.activeSubcategory = "";
        state.activeView = "website-index";
        render();
      });

      els.sideFavorites.addEventListener("click", () => {
        state.favoritesOnly = true;
        state.activeCategory = "all";
        state.activeSubcategory = "";
        state.activeView = "website-index";
        render();
        closeMobileSidebar();
      });

      // ─── Model Arena Click & Dismiss Listeners ───
      document.querySelectorAll(".model-category-btn").forEach((btn) => {
        btn.addEventListener("click", () => {
          playSidePress(btn);
          state.activeView = "model-arena";
          state.activeModelCategory = btn.dataset.modelCategory;
          state.chartScrollOffset = 0; // Reset scroll offset on category switch
          // Hide popover and clear active model ID instantly on category switch
          els.modelPopover.hidden = true;
          els.modelPopover.classList.remove("show");
          state.activeModelId = null;
          render();
          closeMobileSidebar();
        });
      });

      els.xModePrice.addEventListener("click", () => {
        els.modelPopover.hidden = true;
        els.modelPopover.classList.remove("show");
        state.activeModelId = null;
        state.chartScrollOffset = 0; // Reset scroll offset on dimension switch
        const container = els.modelArenaSection.querySelector(".arena-chart-container");
        container.classList.add("animate-positions");
        state.xAxisMode = "price";
        render();
        setTimeout(() => {
          container.classList.remove("animate-positions");
        }, 700);
      });

      els.xModeDate.addEventListener("click", () => {
        els.modelPopover.hidden = true;
        els.modelPopover.classList.remove("show");
        state.activeModelId = null;
        state.chartScrollOffset = 0; // Reset scroll offset on dimension switch
        const container = els.modelArenaSection.querySelector(".arena-chart-container");
        container.classList.add("animate-positions");
        state.xAxisMode = "date";
        render();
        setTimeout(() => {
          container.classList.remove("animate-positions");
        }, 700);
      });

      // ─── Drag Scrolling on Chart Plot Area ───
      let isDragging = false;
      let startX = 0;
      let startScrollOffset = 0;

      let dragPointerId = null; // track which pointer initiated the drag

      els.chartPlotArea.addEventListener("pointerdown", (e) => {
        // Only drag with primary mouse button (left-click) or touch
        if (e.button !== 0 && e.pointerType === "mouse") return;

        isDragging = true;
        state.hasDragged = false;
        startX = e.clientX;
        startScrollOffset = state.chartScrollOffset || 0;
        dragPointerId = e.pointerId;

        // Don't setPointerCapture yet — defer until we confirm it's a real drag.
        // This prevents pointer capture from interfering with click events on capsules
        // (especially on touch devices where finger contact causes tiny movements).
        els.chartPlotArea.style.cursor = "grabbing";

        const container = els.modelArenaSection.querySelector(".arena-chart-container");
        if (container) {
          container.classList.add("is-dragging");
          container.classList.remove("animate-positions");
        }
      });

      els.chartPlotArea.addEventListener("pointermove", (e) => {
        if (!isDragging) return;

        const deltaX = e.clientX - startX;
        // Use a higher threshold for touch to avoid误触 (accidental drag detection)
        // Touch: 15px threshold (finger contact area causes small movements)
        // Mouse: 5px threshold
        const dragThreshold = e.pointerType === "touch" ? 15 : 5;
        if (Math.abs(deltaX) > dragThreshold) {
          // First time crossing the threshold — capture the pointer now that we know it's a real drag
          if (!state.hasDragged && dragPointerId !== null) {
            try { els.chartPlotArea.setPointerCapture(dragPointerId); } catch (_) {}
          }
          state.hasDragged = true;
        }

        const plotWidth = els.chartPlotArea.clientWidth || 1;
        const deltaVirtual = -(deltaX * 100) / plotWidth;

        const zoom = state.chartZoom || 2.6;
        const maxScrollOffset = 100 * (zoom - 1);
        state.chartScrollOffset = Math.max(0, Math.min(maxScrollOffset, startScrollOffset + deltaVirtual));

        updateModelPositionsOnly();
      });

      const endDrag = (e) => {
        if (!isDragging) return;
        isDragging = false;
        els.chartPlotArea.style.cursor = "";
        try {
          els.chartPlotArea.releasePointerCapture(e.pointerId);
        } catch (_) {}
        dragPointerId = null;

        const container = els.modelArenaSection.querySelector(".arena-chart-container");
        if (container) {
          container.classList.remove("is-dragging");
        }
      };

      els.chartPlotArea.addEventListener("pointerup", endDrag);
      els.chartPlotArea.addEventListener("pointercancel", endDrag);

      // ─── Drag/Click Scrolling on Parallel Scrollbar ───
      let isScrollDragging = false;
      let isResizingLeft = false;
      let isResizingRight = false;
      let scrollStartX = 0;
      let scrollStartOffset = 0;

      let startThumbLeft = 0;
      let startThumbWidth = 0;
      let startTrackWidth = 0;

      if (els.chartScrollbarThumb && els.chartScrollbarContainer) {
        // Drag scrolling the thumb itself
        els.chartScrollbarThumb.addEventListener("pointerdown", (e) => {
          // Do not scroll if we clicked a handle
          if (e.target.classList.contains("thumb-handle")) return;
          e.stopPropagation();
          if (e.button !== 0 && e.pointerType === "mouse") return;

          isScrollDragging = true;
          scrollStartX = e.clientX;
          scrollStartOffset = state.chartScrollOffset || 0;

          els.chartScrollbarThumb.style.cursor = "grabbing";
          els.chartScrollbarThumb.setPointerCapture(e.pointerId);

          const container = els.modelArenaSection.querySelector(".arena-chart-container");
          if (container) {
            container.classList.add("is-dragging");
            container.classList.remove("animate-positions");
          }
        });

        els.chartScrollbarThumb.addEventListener("pointermove", (e) => {
          if (!isScrollDragging) return;

          const deltaX = e.clientX - scrollStartX;
          const trackWidth = els.chartScrollbarContainer.clientWidth || 1;

          const zoom = state.chartZoom || 2.6;
          const thumbWidthPercent = (1 / zoom) * 100;
          const maxScrollPixels = trackWidth * (1 - thumbWidthPercent / 100);

          if (maxScrollPixels <= 0) return;

          const maxScrollOffset = 100 * (zoom - 1);
          const deltaOffset = (deltaX / maxScrollPixels) * maxScrollOffset;
          state.chartScrollOffset = Math.max(0, Math.min(maxScrollOffset, scrollStartOffset + deltaOffset));

          updateModelPositionsOnly();
        });

        const endScrollDrag = (e) => {
          if (!isScrollDragging) return;
          isScrollDragging = false;
          els.chartScrollbarThumb.style.cursor = "";
          try {
            els.chartScrollbarThumb.releasePointerCapture(e.pointerId);
          } catch (_) {}

          const container = els.modelArenaSection.querySelector(".arena-chart-container");
          if (container) {
            container.classList.remove("is-dragging");
          }
        };

        els.chartScrollbarThumb.addEventListener("pointerup", endScrollDrag);
        els.chartScrollbarThumb.addEventListener("pointercancel", endScrollDrag);

        // Resize from LEFT handle
        if (els.thumbHandleL) {
          els.thumbHandleL.addEventListener("pointerdown", (e) => {
            e.stopPropagation();
            if (e.button !== 0 && e.pointerType === "mouse") return;

            isResizingLeft = true;
            scrollStartX = e.clientX;

            startTrackWidth = els.chartScrollbarContainer.clientWidth || 1;
            const trackRect = els.chartScrollbarContainer.getBoundingClientRect();
            const thumbRect = els.chartScrollbarThumb.getBoundingClientRect();

            startThumbLeft = thumbRect.left - trackRect.left;
            startThumbWidth = thumbRect.width;

            els.thumbHandleL.classList.add("is-dragging");
            els.thumbHandleL.setPointerCapture(e.pointerId);

            const container = els.modelArenaSection.querySelector(".arena-chart-container");
            if (container) {
              container.classList.add("is-dragging");
              container.classList.remove("animate-positions");
            }
          });

          els.thumbHandleL.addEventListener("pointermove", (e) => {
            if (!isResizingLeft) return;

            const deltaX = e.clientX - scrollStartX;
            let newThumbLeft = startThumbLeft + deltaX;
            const minThumbWidth = startTrackWidth / 3.0; // max zoom 3.0
            const startThumbRight = startThumbLeft + startThumbWidth;

            // Constrain left edge
            newThumbLeft = Math.max(0, Math.min(startThumbRight - minThumbWidth, newThumbLeft));

            const newThumbWidth = startThumbRight - newThumbLeft;
            const newZoom = startTrackWidth / newThumbWidth;
            const clampedZoom = Math.max(1.0, Math.min(3.0, newZoom));

            state.chartZoom = clampedZoom;
            state.chartScrollOffset = (newThumbLeft / startTrackWidth) * 100 * clampedZoom;

            // Apply zoom scroll limit constraints
            const maxScrollOffset = 100 * (clampedZoom - 1);
            state.chartScrollOffset = Math.max(0, Math.min(maxScrollOffset, state.chartScrollOffset));

            updateModelPositionsOnly();
          });

          const endResizeLeft = (e) => {
            if (!isResizingLeft) return;
            isResizingLeft = false;
            els.thumbHandleL.classList.remove("is-dragging");
            try {
              els.thumbHandleL.releasePointerCapture(e.pointerId);
            } catch (_) {}

            const container = els.modelArenaSection.querySelector(".arena-chart-container");
            if (container) {
              container.classList.remove("is-dragging");
            }
          };

          els.thumbHandleL.addEventListener("pointerup", endResizeLeft);
          els.thumbHandleL.addEventListener("pointercancel", endResizeLeft);
        }

        // Resize from RIGHT handle
        if (els.thumbHandleR) {
          els.thumbHandleR.addEventListener("pointerdown", (e) => {
            e.stopPropagation();
            if (e.button !== 0 && e.pointerType === "mouse") return;

            isResizingRight = true;
            scrollStartX = e.clientX;

            startTrackWidth = els.chartScrollbarContainer.clientWidth || 1;
            const trackRect = els.chartScrollbarContainer.getBoundingClientRect();
            const thumbRect = els.chartScrollbarThumb.getBoundingClientRect();

            startThumbLeft = thumbRect.left - trackRect.left;
            startThumbWidth = thumbRect.width;

            els.thumbHandleR.classList.add("is-dragging");
            els.thumbHandleR.setPointerCapture(e.pointerId);

            const container = els.modelArenaSection.querySelector(".arena-chart-container");
            if (container) {
              container.classList.add("is-dragging");
              container.classList.remove("animate-positions");
            }
          });

          els.thumbHandleR.addEventListener("pointermove", (e) => {
            if (!isResizingRight) return;

            const deltaX = e.clientX - scrollStartX;
            const newThumbWidth = Math.max(startTrackWidth / 3.0, Math.min(startTrackWidth - startThumbLeft, startThumbWidth + deltaX));

            const newZoom = startTrackWidth / newThumbWidth;
            const clampedZoom = Math.max(1.0, Math.min(3.0, newZoom));

            state.chartZoom = clampedZoom;
            state.chartScrollOffset = (startThumbLeft / startTrackWidth) * 100 * clampedZoom;

            const maxScrollOffset = 100 * (clampedZoom - 1);
            state.chartScrollOffset = Math.max(0, Math.min(maxScrollOffset, state.chartScrollOffset));

            updateModelPositionsOnly();
          });

          const endResizeRight = (e) => {
            if (!isResizingRight) return;
            isResizingRight = false;
            els.thumbHandleR.classList.remove("is-dragging");
            try {
              els.thumbHandleR.releasePointerCapture(e.pointerId);
            } catch (_) {}

            const container = els.modelArenaSection.querySelector(".arena-chart-container");
            if (container) {
              container.classList.remove("is-dragging");
            }
          };

          els.thumbHandleR.addEventListener("pointerup", endResizeRight);
          els.thumbHandleR.addEventListener("pointercancel", endResizeRight);
        }

        // Click on track to jump scroll and immediately start drag
        els.chartScrollbarContainer.addEventListener("pointerdown", (e) => {
          if (e.target === els.chartScrollbarThumb) return;
          if (e.target.classList.contains("thumb-handle")) return; // ignore handle clicks
          if (e.button !== 0 && e.pointerType === "mouse") return;

          const trackRect = els.chartScrollbarContainer.getBoundingClientRect();
          const trackWidth = trackRect.width || 1;

          const zoom = state.chartZoom || 2.6;
          const thumbWidthPercent = (1 / zoom) * 100;
          const thumbWidth = trackWidth * (thumbWidthPercent / 100);
          const maxScrollPixels = trackWidth - thumbWidth;

          if (maxScrollPixels <= 0) return;

          const clickX = e.clientX - trackRect.left;
          const targetThumbLeft = clickX - thumbWidth / 2;
          const ratio = Math.max(0, Math.min(1, targetThumbLeft / maxScrollPixels));

          const maxScrollOffset = 100 * (zoom - 1);
          state.chartScrollOffset = ratio * maxScrollOffset;

          const container = els.modelArenaSection.querySelector(".arena-chart-container");
          if (container) {
            container.classList.add("animate-positions");
          }

          updateModelPositionsOnly();

          // smooth chain drag
          isScrollDragging = true;
          scrollStartX = e.clientX;
          scrollStartOffset = state.chartScrollOffset;
          els.chartScrollbarThumb.style.cursor = "grabbing";
          els.chartScrollbarThumb.setPointerCapture(e.pointerId);
        });
      }

      // Global capture phase click interceptor to isolate drag gestures from detail popover clicks
      document.addEventListener("click", (e) => {
        if (state.hasDragged) {
          e.stopPropagation();
          e.preventDefault();
          state.hasDragged = false;
        }
      }, true);

      if (els.chartZoomSlider) {
        els.chartZoomSlider.addEventListener("input", (e) => {
          const newZoom = parseFloat(e.target.value);
          state.chartZoom = newZoom;

          // Constrain offset
          const maxScrollOffset = 100 * (newZoom - 1);
          state.chartScrollOffset = Math.max(0, Math.min(maxScrollOffset, state.chartScrollOffset));

          updateModelPositionsOnly();
        });
      }

      if (els.chartZoomIcon) {
        const resetZoom = () => {
          state.chartZoom = 2.6;
          // Constrain offset
          const maxScrollOffset = 100 * (2.6 - 1);
          state.chartScrollOffset = Math.max(0, Math.min(maxScrollOffset, state.chartScrollOffset));
          updateModelPositionsOnly();
        };
        els.chartZoomIcon.addEventListener("dblclick", resetZoom);
        els.chartZoomIcon.addEventListener("click", resetZoom);
      }

      els.popoverClose.addEventListener("click", () => {
        closeModelPopover();
      });

      if (els.capsuleSizeSlider) {
        els.capsuleSizeSlider.addEventListener("input", (e) => {
          state.capsuleSize = parseFloat(e.target.value);
          if (els.capsuleSizeVal) {
            els.capsuleSizeVal.textContent = `${state.capsuleSize.toFixed(1)}x`;
          }
          els.chartPlotArea.style.setProperty('--capsule-scale', String(state.capsuleSize));
          if (state.activeModelId) {
            const activeCapsule = els.chartPlotArea.querySelector(`.model-capsule[data-id="${state.activeModelId}"]`);
            if (activeCapsule) {
              repositionModelPopover(activeCapsule);
            }
          }
        });
      }

      if (els.viewModeStandard) {
        els.viewModeStandard.addEventListener("click", () => {
          if (state.observationMode === "standard") return;
          state.observationMode = "standard";
          renderModelArena();
        });
      }

      if (els.viewModeIconOnly) {
        els.viewModeIconOnly.addEventListener("click", () => {
          if (state.observationMode === "icon-only") return;
          state.observationMode = "icon-only";
          renderModelArena();
        });
      }

      document.addEventListener("click", (e) => {
        if (state.activeView === "model-arena") {
          if (!e.target.closest(".model-capsule") &&
              !e.target.closest(".model-popover") &&
              !e.target.closest(".model-category-btn") &&
              !e.target.closest(".axis-control-btn") &&
              !e.target.closest(".control-slider") &&
              !e.target.closest(".mode-toggle-btn") &&
              !e.target.closest(".site-dialog") &&
              !e.target.closest(".game-dialog")) {
            closeModelPopover();
          }
        }
      });

      els.dinoGameButton.addEventListener("click", openGameWindow);
      els.gameClose.addEventListener("click", closeGameWindow);
      els.gameDialog.addEventListener("click", (event) => {
        if (event.target === els.gameDialog) closeGameWindow();
      });

      // 个人介绍按钮 → 平滑滚动到简介面板
      const personalBtn = document.getElementById("personalIntroBtn");
      if (personalBtn) {
        personalBtn.addEventListener("click", () => {
          const section = document.getElementById("personalSection");
          if (section) {
            section.scrollIntoView({ behavior: "smooth", block: "start" });
          }
          // 如果封面还开着，先关闭
          if (!document.body.classList.contains("toolbox-open")) {
            document.body.classList.add("toolbox-open");
            document.querySelector(".hero")?.setAttribute("aria-hidden", "true");
          }
          closeMobileSidebar();
        });
      }

      els.randomButton.addEventListener("click", () => {
        let cards = [...document.querySelectorAll(".site-card")];
        if (!cards.length) {
          if (!state.sites.length) state.sites = FALLBACK_SITES;
          state.search = "";
          els.search.value = "";
          state.activeCategory = "all";
          state.activeSubcategory = "";
          state.favoritesOnly = false;
          render();
          cards = [...document.querySelectorAll(".site-card")];
        }
        const card = cards[Math.floor(Math.random() * cards.length)];
        if (!card) return;
        card.classList.remove("is-pulsing");
        void card.offsetWidth;
        card.classList.add("is-pulsing");
        card.scrollIntoView({ behavior: "smooth", block: "center" });
        window.setTimeout(() => card.classList.remove("is-pulsing"), 1200);
      });

      els.themeToggle.addEventListener("click", () => {
        const next = document.documentElement.dataset.theme === "light" ? "dark" : "light";
        document.documentElement.dataset.theme = next;
      });

      els.menuButton.addEventListener("click", () => {
        const isMobile = window.matchMedia("(max-width: 767px)").matches;
        if (isMobile) {
          const isOpen = els.sidebar.classList.toggle("is-open");
          els.backdrop.classList.toggle("is-open", isOpen);
        } else {
          document.body.classList.toggle("sidebar-collapsed");
          els.sidebar.classList.remove("is-open");
          els.backdrop.classList.remove("is-open");
        }
        updateMenuButtonState();
        window.requestAnimationFrame(updatePageScrollbar);
      });

      els.backdrop.addEventListener("click", () => {
        closeMobileSidebar();
        updateMenuButtonState();
      });
      window.addEventListener("keydown", (event) => {
        if (event.key === "Escape") {
          closeMobileSidebar();
          updateMenuButtonState();
        }
      });

      // Prevent accidental text selection while dragging or inside the chart
      const chartContainer = els.modelArenaSection ? els.modelArenaSection.querySelector(".arena-chart-container") : null;
      if (chartContainer) {
        chartContainer.addEventListener("selectstart", (e) => {
          e.preventDefault();
        });
      }
      window.addEventListener("selectstart", (e) => {
        if (isDragging || isScrollDragging || isResizingLeft || isResizingRight) {
          e.preventDefault();
        }
      });

      updateMenuButtonState();
    }


    function startInkParticles() {
      const canvas = document.getElementById("inkCanvas");
      const ctx = canvas.getContext("2d");
      const particles = [];
      let width = 0;
      let height = 0;
      let raf = 0;
      let paused = false;
      const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
      const pointer = {
        x: 0,
        y: 0,
        active: false,
        radius: 150
      };

      function resize() {
        const dpr = Math.min(window.devicePixelRatio || 1, 2);
        width = window.innerWidth;
        height = window.innerHeight;
        canvas.width = Math.floor(width * dpr);
        canvas.height = Math.floor(height * dpr);
        canvas.style.width = `${width}px`;
        canvas.style.height = `${height}px`;
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      }

      function createParticle(index) {
        return {
          x: Math.random() * width,
          y: Math.random() * height,
          vx: 0,
          vy: 0,
          size: 1 + Math.random() * 2,
          speed: 0.08 + Math.random() * 0.28,
          phase: Math.random() * Math.PI * 2,
          color: index % 3 === 0 ? "rgba(237,232,245,.48)" : "rgba(192,132,252,.44)"
        };
      }

      function draw() {
        if (paused) return;
        ctx.clearRect(0, 0, width, height);
        particles.forEach((particle) => {
          if (pointer.active && !reduceMotion.matches) {
            const dx = particle.x - pointer.x;
            const dy = particle.y - pointer.y;
            const distance = Math.hypot(dx, dy);
            if (distance > 0 && distance < pointer.radius) {
              const force = (1 - distance / pointer.radius) ** 2;
              particle.vx += (dx / distance) * force * 1.55;
              particle.vy += (dy / distance) * force * 1.55;
            }
          }

          particle.vx *= 0.92;
          particle.vy *= 0.92;
          particle.x += particle.vx;
          particle.y += particle.vy - particle.speed;
          particle.phase += 0.012;
          if (particle.y < -20) {
            particle.y = height + 20;
            particle.x = Math.random() * width;
            particle.vx = 0;
            particle.vy = 0;
          }
          if (particle.x < -30) particle.x = width + 30;
          if (particle.x > width + 30) particle.x = -30;
          if (particle.y > height + 30) particle.y = -30;
          const edgeFade = Math.min(1, particle.y / 90, (height - particle.y) / 90);
          ctx.globalAlpha = Math.max(0, edgeFade);
          ctx.fillStyle = particle.color;
          ctx.beginPath();
          ctx.arc(particle.x + Math.sin(particle.phase) * 10, particle.y, particle.size, 0, Math.PI * 2);
          ctx.fill();
        });
        ctx.globalAlpha = 1;
        raf = requestAnimationFrame(draw);
      }

      resize();
      const particleCount = window.matchMedia("(max-width: 720px)").matches ? 64 : 96;
      for (let i = 0; i < particleCount; i += 1) particles.push(createParticle(i));
      window.addEventListener("resize", resize);
      window.addEventListener("pointermove", (event) => {
        pointer.x = event.clientX;
        pointer.y = event.clientY;
        pointer.active = true;
      }, { passive: true });
      window.addEventListener("pointerleave", () => {
        pointer.active = false;
      });
      window.addEventListener("blur", () => {
        pointer.active = false;
      });
      document.addEventListener("visibilitychange", () => {
        paused = document.hidden;
        if (!paused) {
          cancelAnimationFrame(raf);
          draw();
        }
      });
      draw();
    }

    document.addEventListener("DOMContentLoaded", () => {
      bindEvents();
      startInkParticles();
      loadData();
    });
  </script>
</body>
</html>
