    .hf-badge-link {
      font-size: 10px;
      background: rgba(251, 191, 36, 0.15);
      border: 1px solid rgba(251, 191, 36, 0.3);
      border-radius: 4px;
      padding: 2px 6px;
      color: #fbbf24;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      margin-left: auto;
