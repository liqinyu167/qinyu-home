    .hf-badge-link[hidden] {
      display: none;
    }

    .hf-badge-link:hover {
      background: rgba(251, 191, 36, 0.25);
      border-color: #fbbf24;
    }

    .side-link.model-category-btn.active {
      background: rgba(192, 132, 252, 0.12);
      color: var(--ink-accent);
      border-color: rgba(192, 132, 252, 0.3);
      font-weight: bold;
    }

    /* ─── Card Neon Breath Glow Animation ─── */
    @keyframes highlight-glow {
      0% {
        box-shadow: 0 0 0 0px rgba(192, 132, 252, 0.8), 0 0 10px rgba(192, 132, 252, 0.4);
        border-color: rgba(192, 132, 252, 1);
      }
      50% {
        box-shadow: 0 0 0 10px rgba(192, 132, 252, 0), 0 0 30px rgba(192, 132, 252, 0.8);
        border-color: rgba(192, 132, 252, 1);
      }
      100% {
        box-shadow: 0 0 0 0px rgba(192, 132, 252, 0), 0 0 0px rgba(192, 132, 252, 0);
      }
    }

    .site-card.highlight-flash {
      animation: highlight-glow 1.5s ease-out 1;
    }

    @media (prefers-reduced-motion: reduce) {
      *,
      *::before,
      *::after {
        scroll-behavior: auto !important;
        animation-duration: 0.001ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.001ms !important;
      }

    }

    @media (min-width: 768px) {
      body.sidebar-collapsed .sidebar {
        opacity: 0 !important;
        pointer-events: none;
        transform: translateX(calc(-1 * var(--sidebar-w))) !important;
      }
    }
  /* ===== 个人简介（扁平面板，位于封面与工具箱之间） ===== */
